*.mdf
*.ldf
*.ndf
*.db
*.db-shm
*.db-wal
*.sqlite
*.sqlite3

# ========== Application Specific ==========

# Sensitive configuration
appsettings.Development.json
appsettings.*.json
!appsettings.json
config.json

# User uploads
wwwroot/uploads/
wwwroot/images/

# ML Models (uncomment if too large to commit)
# MLModels/*.zip

# Migrations (keep them - professor needs to see)
# Migrations/

# ========== Rider ==========
.idea/
*.sln.iml
_ReSharper*/
*.DotSettings.user

