@implements IDisposable
@inject NavigationManager Navigation

<nav class="sidebar-nav">
    <div class="nav-section">
        <span class="nav-section-title">Main</span>
        
        <NavLink class="nav-item" href="" Match="NavLinkMatch.All">
            <span class="nav-icon">📊</span>
            <span class="nav-text">Dashboard</span>
        </NavLink>
    </div>

    <div class="nav-section">
        <span class="nav-section-title">Management</span>
        
        <NavLink class="nav-item" href="/admin">
            <span class="nav-icon">⚙️</span>
            <span class="nav-text">Admin Panel</span>
        </NavLink>
    </div>

    <div class="nav-section">
        <span class="nav-section-title">Resources</span>
        
        <a class="nav-item" href="https://matematiranje.in.rs/" target="_blank">
            <span class="nav-icon">📚</span>
            <span class="nav-text">Documentation</span>
            <span class="nav-badge">New</span>
        </a>
    </div>

    <!-- Status Indicator -->
    <div class="nav-footer">
        <div class="status-indicator @(isConnected ? "connected" : "disconnected")">
            <span class="status-dot"></span>
            <span class="status-text">@(isConnected ? "Agent Online" : "Agent Offline")</span>
        </div>
    </div>
</nav>

@code {
    private bool isConnected = true;

    protected override void OnInitialized()
    {
        Navigation.LocationChanged += OnLocationChanged;
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        StateHasChanged();
    }

    public void Dispose()
    {
        Navigation.LocationChanged -= OnLocationChanged;
    }
}