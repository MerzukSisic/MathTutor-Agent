@implements IDisposable
@inject NavigationManager Navigation
@inject UiPreferencesService UiPrefs

<nav class="sidebar-nav">
    <AuthorizeView>
        <Authorized Context="authState">
            @if (authState.User.IsInRole(UserRoles.Admin))
            {
                <div class="nav-section">
                    <span class="nav-section-title">@UiPrefs.T("main")</span>

                    <NavLink class="nav-item" href="" Match="NavLinkMatch.All">
                        <span class="nav-icon">📊</span>
                        <span class="nav-text">@UiPrefs.T("dashboard")</span>
                    </NavLink>
                </div>

                <div class="nav-section">
                    <span class="nav-section-title">@UiPrefs.T("management")</span>

                    <NavLink class="nav-item" href="/admin">
                        <span class="nav-icon">⚙️</span>
                        <span class="nav-text">@UiPrefs.T("admin_panel")</span>
                    </NavLink>
                </div>
            }
            else
            {
                var studentId = GetStudentId(authState.User);
                @if (studentId.HasValue)
                {
                    <div class="nav-section">
                        <span class="nav-section-title">@UiPrefs.T("learning")</span>

                        <NavLink class="nav-item" href="@($"/quiz/{studentId.Value}")">
                            <span class="nav-icon">🧠</span>
                            <span class="nav-text">@UiPrefs.T("practice_quiz")</span>
                        </NavLink>

                        <NavLink class="nav-item" href="@($"/profile/{studentId.Value}")">
                            <span class="nav-icon">📈</span>
                            <span class="nav-text">@UiPrefs.T("my_profile")</span>
                        </NavLink>
                    </div>
                }
            }

            <div class="nav-section">
                <span class="nav-section-title">@UiPrefs.T("account")</span>

                <div class="nav-item nav-user" title="@authState.User.Identity?.Name">
                    <span class="nav-icon">👤</span>
                    <span class="nav-text">@authState.User.Identity?.Name</span>
                </div>
            </div>
        </Authorized>
        <NotAuthorized>
            <div class="nav-section">
                <span class="nav-section-title">@UiPrefs.T("account")</span>

                <NavLink class="nav-item" href="/login">
                    <span class="nav-icon">🔐</span>
                    <span class="nav-text">@UiPrefs.T("login")</span>
                </NavLink>

                <NavLink class="nav-item" href="/register">
                    <span class="nav-icon">✨</span>
                    <span class="nav-text">@UiPrefs.T("register")</span>
                </NavLink>
            </div>
        </NotAuthorized>
    </AuthorizeView>

    <div class="nav-footer">
        <AuthorizeView>
            <Authorized>
                <div class="nav-footer-actions">
                    <NavLink class="nav-item nav-item-danger" href="/logout">
                        <span class="nav-icon">↩️</span>
                        <span class="nav-text">@UiPrefs.T("logout")</span>
                    </NavLink>
                </div>
            </Authorized>
        </AuthorizeView>

        <div class="status-indicator @(isConnected ? "connected" : "disconnected")">
            <span class="status-dot"></span>
            <span class="status-text">@(isConnected ? UiPrefs.T("agent_online") : UiPrefs.T("agent_offline"))</span>
        </div>
    </div>
</nav>

@code {
    private bool isConnected = true;

    protected override void OnInitialized()
    {
        Navigation.LocationChanged += OnLocationChanged;
        UiPrefs.Changed += OnUiPreferencesChanged;
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        _ = InvokeAsync(StateHasChanged);
    }

    private void OnUiPreferencesChanged()
    {
        _ = InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        Navigation.LocationChanged -= OnLocationChanged;
        UiPrefs.Changed -= OnUiPreferencesChanged;
    }

    private static int? GetStudentId(ClaimsPrincipal user)
    {
        var claimValue = user.FindFirst("student_id")?.Value;
        return int.TryParse(claimValue, out var studentId) ? studentId : null;
    }
}
