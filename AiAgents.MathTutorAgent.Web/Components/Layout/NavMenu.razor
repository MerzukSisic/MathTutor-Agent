@implements IDisposable
@inject NavigationManager Navigation

<nav class="sidebar-nav">
    <AuthorizeView>
        <Authorized Context="authState">
            @if (authState.User.IsInRole(UserRoles.Admin))
            {
                <div class="nav-section">
                    <span class="nav-section-title">Main</span>

                    <NavLink class="nav-item" href="" Match="NavLinkMatch.All">
                        <span class="nav-icon">📊</span>
                        <span class="nav-text">Dashboard</span>
                    </NavLink>
                </div>

                <div class="nav-section">
                    <span class="nav-section-title">Management</span>

                    <NavLink class="nav-item" href="/admin">
                        <span class="nav-icon">⚙️</span>
                        <span class="nav-text">Admin Panel</span>
                    </NavLink>
                </div>
            }
            else
            {
                var studentId = GetStudentId(authState.User);
                <div class="nav-section">
                    <span class="nav-section-title">Learning</span>

                    @if (studentId.HasValue)
                    {
                        <NavLink class="nav-item" href="@($"/quiz/{studentId.Value}")">
                            <span class="nav-icon">🧠</span>
                            <span class="nav-text">Practice Quiz</span>
                        </NavLink>

                        <NavLink class="nav-item" href="@($"/profile/{studentId.Value}")">
                            <span class="nav-icon">📈</span>
                            <span class="nav-text">My Profile</span>
                        </NavLink>
                    }
                </div>
            }

            <div class="nav-section">
                <span class="nav-section-title">Account</span>

                <div class="nav-item nav-user" title="@authState.User.Identity?.Name">
                    <span class="nav-icon">👤</span>
                    <span class="nav-text">@authState.User.Identity?.Name</span>
                </div>

                <NavLink class="nav-item nav-item-danger" href="/logout">
                    <span class="nav-icon">↩️</span>
                    <span class="nav-text">Logout</span>
                </NavLink>
            </div>
        </Authorized>
        <NotAuthorized>
            <div class="nav-section">
                <span class="nav-section-title">Account</span>

                <NavLink class="nav-item" href="/login">
                    <span class="nav-icon">🔐</span>
                    <span class="nav-text">Login</span>
                </NavLink>

                <NavLink class="nav-item" href="/register">
                    <span class="nav-icon">✨</span>
                    <span class="nav-text">Register</span>
                </NavLink>
            </div>
        </NotAuthorized>
    </AuthorizeView>

    <div class="nav-section">
        <span class="nav-section-title">Resources</span>
        
        <a class="nav-item" href="https://matematiranje.in.rs/" target="_blank">
            <span class="nav-icon">📚</span>
            <span class="nav-text">Documentation</span>
            <span class="nav-badge">New</span>
        </a>
    </div>

    <!-- Status Indicator -->
    <div class="nav-footer">
        <div class="status-indicator @(isConnected ? "connected" : "disconnected")">
            <span class="status-dot"></span>
            <span class="status-text">@(isConnected ? "Agent Online" : "Agent Offline")</span>
        </div>
    </div>
</nav>

@code {
    private bool isConnected = true;

    protected override void OnInitialized()
    {
        Navigation.LocationChanged += OnLocationChanged;
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        StateHasChanged();
    }

    public void Dispose()
    {
        Navigation.LocationChanged -= OnLocationChanged;
    }

    private static int? GetStudentId(ClaimsPrincipal user)
    {
        var claimValue = user.FindFirst("student_id")?.Value;
        return int.TryParse(claimValue, out var studentId) ? studentId : null;
    }
}
