@using Radzen.Blazor
@inherits LayoutComponentBase
@inject NavigationManager Navigation
@implements IDisposable

@if (IsAuthRoute)
{
    <main class="auth-layout-main">
        @Body
    </main>
}
else
{
    <div class="app-container @(isSidebarOpen ? "sidebar-open" : string.Empty)">
        <div class="sidebar-overlay" @onclick="CloseSidebar"></div>

        <!-- Sidebar Navigation -->
        <aside class="app-sidebar">
            <div class="sidebar-header">
                <div class="logo">
                    <span class="logo-icon">🧮</span>
                    <span class="logo-text">MathTutor AI</span>
                </div>
            </div>
            <NavMenu />
        </aside>

        <!-- Main Content Area -->
        <div class="app-main">
            <!-- Top Bar -->
            <header class="app-header">
                <div class="header-content">
                    <div class="header-left">
                        <button class="menu-toggle" @onclick="ToggleSidebar" aria-label="Toggle menu">☰</button>
                        <h1 class="page-title">@GetCurrentPageTitle()</h1>
                    </div>
                </div>
            </header>

            <!-- Page Content -->
            <main class="app-content">
                <div class="content-wrapper">
                    @Body
                </div>
            </main>

            <!-- Footer -->
            <footer class="app-footer">
                <p>MathTutor AI Agent © 2025 | Built with .NET 9 & ML.NET</p>
            </footer>
        </div>
    </div>
}

<!-- Error UI -->
<div id="blazor-error-ui">
    <div class="error-content">
        <span class="error-icon">⚠️</span>
        <span class="error-message">An error occurred</span>
        <a href="" class="btn-reload">Reload</a>
        <button class="btn-dismiss">✕</button>
    </div>
</div>

@code {
    private bool isSidebarOpen;
    private bool IsAuthRoute => IsAuthPath();

    protected override void OnInitialized()
    {
        Navigation.LocationChanged += OnLocationChanged;
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        isSidebarOpen = false;
        InvokeAsync(StateHasChanged);
    }

    private void ToggleSidebar()
    {
        isSidebarOpen = !isSidebarOpen;
    }

    private void CloseSidebar()
    {
        isSidebarOpen = false;
    }

    private string GetCurrentPageTitle()
    {
        var path = Navigation.ToAbsoluteUri(Navigation.Uri).AbsolutePath.Trim('/').ToLowerInvariant();
        return path switch
        {
            "" or "dashboard" => "Dashboard",
            "admin" => "Admin Panel",
            "admin/add-student" => "Add Student",
            "admin/add-question" => "Add Question",
            var p when p.StartsWith("admin/edit-student/") => "Edit Student",
            var p when p.StartsWith("quiz/") => "Practice Quiz",
            var p when p.StartsWith("profile/") => "Student Profile",
            var p when p.StartsWith("admin/edit-question/") => "Edit Question",
            "login" => "Sign In",
            "register" => "Register",
            "confirm_email" => "Confirm Email",
            "forgot_password" => "Forgot Password",
            "reset_password" => "Reset Password",
            "resend_confirmation" => "Resend Confirmation",
            _ => "MathTutor AI"
        };
    }

    private bool IsAuthPath()
    {
        var path = Navigation.ToAbsoluteUri(Navigation.Uri).AbsolutePath.Trim('/').ToLowerInvariant();
        return path is "login" or "register" or "confirm_email" or "forgot_password" or "reset_password" or "resend_confirmation";
    }

    public void Dispose()
    {
        Navigation.LocationChanged -= OnLocationChanged;
    }
}
