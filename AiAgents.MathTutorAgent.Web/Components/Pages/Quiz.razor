@page "/quiz/{studentId:int}"
@attribute [Authorize]
@using Microsoft.AspNetCore.SignalR.Client
@inject NavigationManager Navigation
@inject HttpClient Http
@implements IAsyncDisposable

<PageTitle>Quiz - MathTutor AI</PageTitle>

<div class="quiz-container">
    @if (currentQuestion != null)
    {
        <div class="question-card">
            <!-- ✅ Loading Overlay -->
            @if (isLoading || isSubmitting)
            {
                <div class="loading-overlay">
                    <div class="spinner"></div>
                    <p>@(isSubmitting ? "Submitting answer..." : "Loading next question...")</p>
                </div>
            }

            <div class="question-header">
                <h2>Question @currentQuestion.Id</h2>
                <div class="question-badges">
                    @if (!string.IsNullOrWhiteSpace(currentQuestion.AreaName))
                    {
                        <span class="area-badge">@currentQuestion.AreaName</span>
                    }
                    <span class="difficulty-badge difficulty-@currentQuestion.Difficulty">
                        Difficulty: @currentQuestion.Difficulty
                    </span>
                    <span class="timer-badge @(remainingSeconds <= 10 ? "timer-warning" : string.Empty)">
                        ⏱️ @remainingSeconds s left
                    </span>
                </div>
            </div>

            <div class="timer-track" role="progressbar" aria-valuemin="0" aria-valuemax="@timeLimitSeconds" aria-valuenow="@remainingSeconds">
                <div class="timer-fill @(remainingSeconds <= 10 ? "critical" : string.Empty)"
                     style="width:@($"{TimeProgressPercent:F1}%")"></div>
            </div>
            <div class="timer-meta">
                <span>Limit: @timeLimitSeconds s</span>
                <span class="timer-hint">@GetTimerHint()</span>
            </div>

            <div class="question-body">
                <p class="question-text">@currentQuestion.QuestionText</p>

                @if (geometryInteraction != null)
                {
                    <GeometryClickPractice Model="geometryInteraction"
                                           Disabled="@(isSubmitting || isLoading)"
                                           OnSelectionChanged="HandleGeometrySelectionChanged" />
                }

                @if (visualPractice != null)
                {
                    <div class="visual-practice">
                        <h4>🎮 Mini Practice</h4>

                        @if (visualPractice.Mode == "addition")
                        {
                            <div class="crossmath-strip">
                                <span class="math-tile">@visualPractice.A</span>
                                <span class="math-op">+</span>
                                <span class="math-tile">@visualPractice.B</span>
                                <span class="math-op">=</span>
                                <span class="math-tile answer">@GetVisualResult()</span>
                            </div>
                            <p>Drag or click apples to move them into the answer basket.</p>
                            <div class="apple-playground">
                                <div class="apple-source">
                                    <strong>Group A (@visualPractice.SourceA left)</strong>
                                    <div class="apple-row">
                                        @for (var i = 0; i < visualPractice.SourceA; i++)
                                        {
                                            <span class="apple"
                                                  draggable="true"
                                                  @ondragstart="@BeginAppleDragA"
                                                  @onclick="@TakeAppleFromA">🍎</span>
                                        }
                                    </div>
                                </div>
                                <div class="apple-source">
                                    <strong>Group B (@visualPractice.SourceB left)</strong>
                                    <div class="apple-row">
                                        @for (var i = 0; i < visualPractice.SourceB; i++)
                                        {
                                            <span class="apple"
                                                  draggable="true"
                                                  @ondragstart="@BeginAppleDragB"
                                                  @onclick="@TakeAppleFromB">🍎</span>
                                        }
                                    </div>
                                </div>
                                <div class="apple-target"
                                     @ondragover:preventDefault
                                     @ondrop:preventDefault
                                     @ondrop="DropAppleToAnswer">
                                    <strong>Answer Basket</strong>
                                    <p>Apples dropped: @visualPractice.Dropped</p>
                                </div>
                            </div>
                        }
                        else if (visualPractice.Mode == "subtraction")
                        {
                            <div class="crossmath-strip">
                                <span class="math-tile">@visualPractice.A</span>
                                <span class="math-op">-</span>
                                <span class="math-tile">@visualPractice.B</span>
                                <span class="math-op">=</span>
                                <span class="math-tile answer">@GetVisualResult()</span>
                            </div>
                            <p>Drag or click apples away to subtract, then count what remains.</p>
                            <div class="apple-playground">
                                <div class="apple-source">
                                    <strong>Start Basket (@visualPractice.Remaining left)</strong>
                                    <div class="apple-row">
                                        @for (var i = 0; i < visualPractice.Remaining; i++)
                                        {
                                            <span class="apple"
                                                  draggable="true"
                                                  @ondragstart="@BeginAppleDragMain"
                                                  @onclick="@TakeAppleFromMain">🍎</span>
                                        }
                                    </div>
                                </div>
                                <div class="apple-target remove"
                                     @ondragover:preventDefault
                                     @ondrop:preventDefault
                                     @ondrop="DropAppleToRemove">
                                    <strong>Remove Basket</strong>
                                    <p>Removed: @visualPractice.Removed / @visualPractice.B</p>
                                </div>
                            </div>
                        }

                        <button class="btn-use-visual" @onclick="ApplyVisualResult">
                            Use Visual Result (@GetVisualResult())
                        </button>
                    </div>
                }
            </div>

            <div class="answer-section">
                <input type="text"
                       class="answer-input"
                       @bind="userAnswer"
                       @bind:event="oninput"
                       placeholder="@(geometryInteraction != null ? "Click sides/vertices above to fill answer" : "Enter your answer")"
                       readonly="@(geometryInteraction != null)"
                       disabled="@(isSubmitting || isLoading || feedback != null)"
                       @onkeypress="HandleKeyPress"/>

                <div class="action-buttons">
                    <button class="btn-submit"
                            @onclick="() => SubmitAnswer(false)"
                            disabled="@(string.IsNullOrWhiteSpace(userAnswer) || isSubmitting || isLoading || feedback != null)">
                        @if (isSubmitting)
                        {
                            <span class="spinner-small"></span>
                            <span>Submitting...</span>
                        }
                        else
                        {
                            <span>Submit Answer</span>
                        }
                    </button>

                    <button class="btn-explain"
                            @onclick="RequestExplanation"
                            disabled="@(isSubmitting || isLoading)">
                        💡 Explain
                    </button>

                    <button class="btn-back" @onclick="GoBack">
                        ← Back to Dashboard
                    </button>
                </div>
            </div>

            @if (feedback != null)
            {
                <div class="feedback-section @(feedback.IsCorrect ? "correct" : "incorrect")">
                    <h3>@(feedback.IsTimedOut ? "⏰ Time is up!" : feedback.IsCorrect ? "✓ Correct!" : "✗ Incorrect")</h3>
                    <p><strong>Correct Answer:</strong> @feedback.CorrectAnswer</p>
                    <p><strong>Time:</strong> @feedback.TimeSpentSeconds.ToString("F1")s / @feedback.TimeLimitSeconds s</p>
                    <p><strong>Your Mastery:</strong> @feedback.MasteryScore.ToString("F1")%</p>
                    <p><strong>Decision:</strong>
                        <span class="decision-badge decision-@feedback.Decision.ToLower()">
                            @feedback.Decision
                        </span>
                    </p>

                    @if (milestoneChallenge == null)
                    {
                        <button class="btn-next" @onclick="GetNextQuestion">
                            Next Question →
                        </button>
                    }
                    else
                    {
                        <div class="challenge-lock">
                            Complete the chapter challenge below to continue.
                        </div>
                    }
                </div>
            }

            @if (milestoneChallenge != null)
            {
                <CrossMathChallenge Model="milestoneChallenge"
                                    Disabled="@(isSubmitting || isLoading)"
                                    OnCompleted="HandleMilestoneChallengeCompleted" />
            }

            @if (explanation != null)
            {
                <div class="explanation-section">
                    <h3>📚 Explanation</h3>
                    <p>@explanation.Explanation</p>

                    @if (currentQuestion != null)
                    {
                        <AreaVisualGuide AreaName="@currentQuestion.AreaName"
                                         TopicName="@currentQuestion.TopicName"
                                         QuestionText="@currentQuestion.QuestionText" />
                    }

                    @if (!string.IsNullOrEmpty(explanation.Example))
                    {
                        <div class="example-box">
                            <strong>Example:</strong>
                            <p>@explanation.Example</p>
                        </div>
                    }

                    @if (explanation.Sources?.Any() == true)
                    {
                        <div class="sources-section">
                            <strong>📖 Sources:</strong>
                            <ul>
                                @foreach (var source in explanation.Sources)
                                {
                                    <li>@source.Title (@source.PageOrTime)</li>
                                }
                            </ul>
                        </div>
                    }
                </div>
            }
        </div>
    }
    else if (isLoading)
    {
        <div class="loading-container">
            <div class="spinner-large"></div>
            <p>Loading your first question...</p>
        </div>
    }
    else
    {
        <div class="no-question">
            <p>No questions available. Click below to get started.</p>
            <button class="btn-primary" @onclick="GetNextQuestion">
                Get First Question
            </button>
        </div>
    }
</div>
