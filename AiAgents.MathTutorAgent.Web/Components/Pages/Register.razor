@page "/register"
@attribute [AllowAnonymous]
@using System.Text.Json
@using System.Text.Json.Serialization
@using System.Text.RegularExpressions
@inject IJSRuntime JS
@inject NavigationManager Navigation
@inject UiPreferencesService UiPrefs
@inject NotificationService Notifications
@implements IDisposable

<PageTitle>@($"{L("Registracija", "Register")} - MathTutor AI")</PageTitle>

<div class="auth-page">
    <div class="auth-card">
        <h1>@L("Kreiraj nalog", "Create Account")</h1>
        <p>@L("Registruj se i započni adaptivno vježbanje matematike.", "Register and start adaptive math practice.")</p>

        <label>
            @L("Puno ime", "Full Name")
            <input class="auth-input" @bind="fullName" @bind:event="oninput" autocomplete="name" />
            @if (showFullNameError)
            {
                <span class="auth-inline-error">@L("Puno ime je obavezno.", "Full name is required.")</span>
            }
        </label>

        <label>
            @L("Email", "Email")
            <input class="auth-input" type="email" @bind="email" @bind:event="oninput" autocomplete="username" />
            @if (showEmailError)
            {
                <span class="auth-inline-error">@L("Unesi ispravnu email adresu (primjer: ime@email.com).", "Enter a valid email address (example: name@email.com).")</span>
            }
        </label>

        <label>
            @L("Lozinka", "Password")
            <div class="auth-password-wrap">
                <input class="auth-input" type="@(showPassword ? "text" : "password")" @bind="password" @bind:event="oninput" autocomplete="new-password" />
                <button type="button"
                        class="auth-password-toggle"
                        @onclick="TogglePasswordVisibility"
                        aria-label="@(showPassword ? L("Sakrij lozinku", "Hide password") : L("Prikaži lozinku", "Show password"))"
                        aria-pressed="@showPassword">
                    @(showPassword ? L("Sakrij", "Hide") : L("Prikaži", "Show"))
                </button>
            </div>
            @if (showPasswordError)
            {
                <span class="auth-inline-error">@L("Lozinka je preslaba. Koristi najmanje 8 znakova i različite tipove karaktera.", "Password is too weak. Use at least 8 chars with mixed character types.")</span>
            }
        </label>

        <div class="auth-strength">
            <div class="auth-strength-bars">
                @for (var i = 1; i <= 4; i++)
                {
                    <span class="auth-strength-bar @(i <= PasswordStrengthScore ? $"active {PasswordStrengthClass}" : string.Empty)"></span>
                }
            </div>
            <p class="auth-strength-label">@L("Jačina", "Strength"): @PasswordStrengthLabel</p>
            <div class="auth-checklist">
                <span class="auth-check-item @(HasMinLength ? "ok" : string.Empty)">@L("8+ znakova", "8+ chars")</span>
                <span class="auth-check-item @(HasUpper ? "ok" : string.Empty)">@L("Veliko slovo", "Uppercase")</span>
                <span class="auth-check-item @(HasLower ? "ok" : string.Empty)">@L("Malo slovo", "Lowercase")</span>
                <span class="auth-check-item @(HasDigit ? "ok" : string.Empty)">@L("Broj", "Number")</span>
                <span class="auth-check-item @(HasSpecial ? "ok" : string.Empty)">@L("Specijalni znak", "Special char")</span>
            </div>
        </div>

        <button class="auth-btn" @onclick="RegisterAsync" disabled="@(!CanSubmit || isSubmitting)">
            @(isSubmitting ? L("Kreiram...", "Creating...") : L("Kreiraj nalog", "Create Account"))
        </button>

        <p class="auth-meta">@L("Već imaš nalog?", "Already have an account?") <a href="/login">@L("Prijavi se", "Sign in")</a></p>
    </div>
</div>

@code {
    private string fullName = string.Empty;
    private string email = string.Empty;
    private string password = string.Empty;
    private bool isSubmitting;
    private bool attemptedSubmit;
    private bool showPassword;
    private static readonly Regex EmailRegex = new(@"^[^\s@]+@[^\s@]+\.[^\s@]+$", RegexOptions.Compiled);
    private static readonly Regex UpperRegex = new(@"[A-Z]", RegexOptions.Compiled);
    private static readonly Regex LowerRegex = new(@"[a-z]", RegexOptions.Compiled);
    private static readonly Regex DigitRegex = new(@"\d", RegexOptions.Compiled);
    private static readonly Regex SpecialRegex = new(@"[^a-zA-Z0-9]", RegexOptions.Compiled);
    private string L(string bs, string en) => UiPrefs.Language == UiLanguage.Bs ? bs : en;

    private bool HasMinLength => !string.IsNullOrWhiteSpace(password) && password.Length >= 8;
    private bool HasUpper => !string.IsNullOrWhiteSpace(password) && UpperRegex.IsMatch(password);
    private bool HasLower => !string.IsNullOrWhiteSpace(password) && LowerRegex.IsMatch(password);
    private bool HasDigit => !string.IsNullOrWhiteSpace(password) && DigitRegex.IsMatch(password);
    private bool HasSpecial => !string.IsNullOrWhiteSpace(password) && SpecialRegex.IsMatch(password);
    private bool IsEmailValid => !string.IsNullOrWhiteSpace(email) && EmailRegex.IsMatch(email.Trim());
    private int PasswordStrengthScore
    {
        get
        {
            if (string.IsNullOrWhiteSpace(password))
            {
                return 0;
            }

            return new[] { HasMinLength, HasUpper, HasLower, HasDigit, HasSpecial }.Count(x => x) switch
            {
                <= 1 => 1,
                2 => 2,
                3 or 4 => 3,
                _ => 4
            };
        }
    }
    private bool IsPasswordStrongEnough => HasMinLength && HasUpper && HasLower && (HasDigit || HasSpecial);
    private bool CanSubmit => !string.IsNullOrWhiteSpace(fullName) && IsEmailValid && IsPasswordStrongEnough;
    private bool showFullNameError => attemptedSubmit && string.IsNullOrWhiteSpace(fullName);
    private bool showEmailError => (!string.IsNullOrWhiteSpace(email) || attemptedSubmit) && !IsEmailValid;
    private bool showPasswordError => (!string.IsNullOrWhiteSpace(password) || attemptedSubmit) && !IsPasswordStrongEnough;
    private string PasswordStrengthClass => PasswordStrengthScore <= 1 ? "weak" : PasswordStrengthScore <= 2 ? "medium" : PasswordStrengthScore == 3 ? "good" : "strong";
    private string PasswordStrengthLabel => string.IsNullOrWhiteSpace(password)
        ? L("Bez lozinke", "No password")
        : PasswordStrengthClass switch
        {
            "weak" => L("Slaba", "Weak"),
            "medium" => L("Srednja", "Medium"),
            "good" => L("Dobra", "Good"),
            _ => L("Jaka", "Strong")
        };

    protected override void OnInitialized()
    {
        UiPrefs.Changed += HandleLanguageChanged;
    }

    private void HandleLanguageChanged()
    {
        _ = InvokeAsync(StateHasChanged);
    }

    private void TogglePasswordVisibility()
    {
        showPassword = !showPassword;
    }

    private async Task RegisterAsync()
    {
        attemptedSubmit = true;

        if (string.IsNullOrWhiteSpace(fullName))
        {
            NotifyWarning(L("Puno ime je obavezno.", "Full name is required."));
            return;
        }

        if (!IsEmailValid)
        {
            NotifyWarning(L("Unesi ispravnu email adresu.", "Please enter a valid email address."));
            return;
        }

        if (!IsPasswordStrongEnough)
        {
            NotifyWarning(L("Lozinka je preslaba. Dodaj više različitih karaktera.", "Password is too weak. Add more variety (upper/lower/digit/special)."));
            return;
        }

        isSubmitting = true;

        try
        {
            var result = await JS.InvokeAsync<JsonElement>("authFetch", "/api/auth/register",
                new { fullName, email, password });

            var ok = result.GetProperty("ok").GetBoolean();
            if (!ok)
            {
                string? msg = null;
                if (result.TryGetProperty("data", out var data) && data.ValueKind != JsonValueKind.Null)
                {
                    data.TryGetProperty("message", out var msgEl);
                    msg = msgEl.ValueKind == JsonValueKind.String ? msgEl.GetString() : null;
                }
                var errorMessage = string.IsNullOrWhiteSpace(msg)
                    ? L("Registracija nije uspjela. Probaj drugi email.", "Registration failed. Try another email.")
                    : LocalizeServerMessage(msg);
                NotifyError(errorMessage);
                return;
            }

            string? message = null;
            AuthUserDto? user = null;
            if (result.TryGetProperty("data", out var authData) && authData.ValueKind != JsonValueKind.Null)
            {
                authData.TryGetProperty("message", out var msgEl);
                message = msgEl.ValueKind == JsonValueKind.String ? msgEl.GetString() : null;

                if (authData.TryGetProperty("user", out var userEl) && userEl.ValueKind != JsonValueKind.Null)
                {
                    user = JsonSerializer.Deserialize<AuthUserDto>(userEl.GetRawText(),
                        new JsonSerializerOptions
                        {
                            PropertyNameCaseInsensitive = true,
                            NumberHandling = JsonNumberHandling.AllowReadingFromString
                        });
                }
            }

            var successMessage = string.IsNullOrWhiteSpace(message)
                ? L("Registracija uspješna. Provjeri email za potvrdu naloga.", "Registration successful. Check your email to confirm account.")
                : message;
            NotifySuccess(successMessage);
            await Task.Delay(1200);
            var status = user?.EmailConfirmed == true ? "registered-ready" : "registered";
            Navigation.NavigateTo($"/login?status={status}", forceLoad: true);
        }
        catch
        {
            NotifyError(L("Registracija nije uspjela. Pokušaj ponovo.", "Registration failed. Please try again."));
        }
        finally
        {
            isSubmitting = false;
        }
    }

    public void Dispose()
    {
        UiPrefs.Changed -= HandleLanguageChanged;
    }

    private string LocalizeServerMessage(string message)
    {
        if (UiPrefs.Language == UiLanguage.En)
        {
            return message;
        }

        if (message.Contains("Email already in use", StringComparison.OrdinalIgnoreCase))
        {
            return "Email je već zauzet. Ako te je nastavnik pozvao, klikni 'Zaboravljena lozinka' i postavi svoju šifru.";
        }

        return message;
    }

    private void NotifySuccess(string detail)
        => Notifications.Notify(NotificationSeverity.Success, L("Uspješno", "Success"), detail, 5000);

    private void NotifyWarning(string detail)
        => Notifications.Notify(NotificationSeverity.Warning, L("Provjeri unos", "Check input"), detail, 5000);

    private void NotifyError(string detail)
        => Notifications.Notify(NotificationSeverity.Error, L("Neuspješno", "Failed"), detail, 6500);
}
