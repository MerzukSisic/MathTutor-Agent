@page "/reset_password"
@attribute [AllowAnonymous]
@using Microsoft.AspNetCore.WebUtilities
@using System.Text.Json
@inject IJSRuntime JS
@inject NavigationManager Navigation
@inject UiPreferencesService UiPrefs
@inject NotificationService Notifications
@implements IDisposable

<PageTitle>@($"{L("Reset lozinke", "Reset Password")} - MathTutor AI")</PageTitle>

<div class="auth-page">
    <div class="auth-card">
        <h1>@L("Reset lozinke", "Reset Password")</h1>
        <p>@L("Postavi novu lozinku za svoj nalog.", "Set a new password for your account.")</p>

        <label>
            @L("Email", "Email")
            <input class="auth-input" type="email" @bind="email" autocomplete="username" />
        </label>

        <label>
            @L("Nova lozinka", "New Password")
            <div class="auth-password-wrap">
                <input class="auth-input" type="@(showNewPassword ? "text" : "password")" @bind="newPassword" autocomplete="new-password" />
                <button type="button"
                        class="auth-password-toggle"
                        @onclick="TogglePasswordVisibility"
                        aria-label="@(showNewPassword ? L("Sakrij lozinku", "Hide password") : L("Prikaži lozinku", "Show password"))"
                        aria-pressed="@showNewPassword">
                    @(showNewPassword ? L("Sakrij", "Hide") : L("Prikaži", "Show"))
                </button>
            </div>
        </label>

        <button class="auth-btn" @onclick="ResetAsync" disabled="@isSubmitting">
            @(isSubmitting ? L("Spremam...", "Saving...") : L("Resetuj lozinku", "Reset Password"))
        </button>

        <p class="auth-meta"><a href="/login">@L("Nazad na prijavu", "Back to login")</a></p>
    </div>
</div>

@code {
    private string email = string.Empty;
    private string token = string.Empty;
    private string newPassword = string.Empty;
    private bool isSubmitting;
    private bool showNewPassword;
    private string L(string bs, string en) => UiPrefs.Language == UiLanguage.Bs ? bs : en;

    protected override void OnInitialized()
    {
        UiPrefs.Changed += HandleLanguageChanged;

        var uri = Navigation.ToAbsoluteUri(Navigation.Uri);
        var query = QueryHelpers.ParseQuery(uri.Query);
        if (query.TryGetValue("email", out var emailValue))
        {
            email = emailValue.ToString();
        }

        if (query.TryGetValue("token", out var tokenValue))
        {
            token = tokenValue.ToString();
        }

        if (string.IsNullOrWhiteSpace(token))
        {
            NotifyError(L("Neispravan link za reset.", "Invalid reset link."));
        }
    }

    private void HandleLanguageChanged()
    {
        _ = InvokeAsync(StateHasChanged);
    }

    private void TogglePasswordVisibility()
    {
        showNewPassword = !showNewPassword;
    }

    private async Task ResetAsync()
    {
        if (string.IsNullOrWhiteSpace(email) || string.IsNullOrWhiteSpace(token))
        {
            NotifyError(L("Neispravan link za reset.", "Invalid reset link."));
            return;
        }

        if (string.IsNullOrWhiteSpace(newPassword) || newPassword.Length < 6)
        {
            NotifyWarning(L("Lozinka mora imati najmanje 6 karaktera.", "Password must be at least 6 characters."));
            return;
        }

        isSubmitting = true;

        try
        {
            var result = await JS.InvokeAsync<JsonElement>("authFetch", "/api/auth/reset_password",
                new { email, token, newPassword });

            if (!result.GetProperty("ok").GetBoolean())
            {
                string? msg = null;
                if (result.TryGetProperty("data", out var data) && data.ValueKind != JsonValueKind.Null)
                {
                    data.TryGetProperty("message", out var msgEl);
                    msg = msgEl.ValueKind == JsonValueKind.String ? msgEl.GetString() : null;
                }

                var errorMessage = string.IsNullOrWhiteSpace(msg) ? L("Link za reset je neispravan ili istekao.", "Reset link is invalid or expired.") : msg;
                NotifyError(errorMessage);
                return;
            }

            NotifySuccess(L("Lozinka je uspješno resetovana.", "Password has been reset successfully."));
            await Task.Delay(1000);
            Navigation.NavigateTo("/login?status=password-reset", forceLoad: true);
        }
        catch
        {
            NotifyError(L("Trenutno nije moguće resetovati lozinku.", "Unable to reset password right now."));
        }
        finally
        {
            isSubmitting = false;
        }
    }

    public void Dispose()
    {
        UiPrefs.Changed -= HandleLanguageChanged;
    }

    private void NotifySuccess(string detail)
        => Notifications.Notify(NotificationSeverity.Success, L("Uspješno", "Success"), detail, 5000);

    private void NotifyWarning(string detail)
        => Notifications.Notify(NotificationSeverity.Warning, L("Provjeri unos", "Check input"), detail, 5000);

    private void NotifyError(string detail)
        => Notifications.Notify(NotificationSeverity.Error, L("Neuspješno", "Failed"), detail, 6500);
}
