@page "/reset_password"
@attribute [AllowAnonymous]
@using Microsoft.AspNetCore.WebUtilities
@using System.Text.Json
@inject IJSRuntime JS
@inject NavigationManager Navigation

<PageTitle>Reset Password - MathTutor AI</PageTitle>

<div class="auth-page">
    <div class="auth-card">
        <h1>Reset Password</h1>
        <p>Set a new password for your account.</p>

        @if (!string.IsNullOrWhiteSpace(message))
        {
            <div class="auth-alert info">@message</div>
        }

        @if (!string.IsNullOrWhiteSpace(errorMessage))
        {
            <div class="auth-alert error">@errorMessage</div>
        }

        <label>
            Email
            <input class="auth-input" type="email" @bind="email" autocomplete="username" />
        </label>

        <label>
            New Password
            <input class="auth-input" type="password" @bind="newPassword" autocomplete="new-password" />
        </label>

        <button class="auth-btn" @onclick="ResetAsync" disabled="@isSubmitting">
            @(isSubmitting ? "Saving..." : "Reset Password")
        </button>

        <p class="auth-meta"><a href="/login">Back to login</a></p>
    </div>
</div>

@code {
    private string email = string.Empty;
    private string token = string.Empty;
    private string newPassword = string.Empty;
    private string? message;
    private string? errorMessage;
    private bool isSubmitting;

    protected override void OnInitialized()
    {
        var uri = Navigation.ToAbsoluteUri(Navigation.Uri);
        var query = QueryHelpers.ParseQuery(uri.Query);
        if (query.TryGetValue("email", out var emailValue))
        {
            email = emailValue.ToString();
        }

        if (query.TryGetValue("token", out var tokenValue))
        {
            token = tokenValue.ToString();
        }

        if (string.IsNullOrWhiteSpace(token))
        {
            errorMessage = "Invalid reset link.";
        }
    }

    private async Task ResetAsync()
    {
        message = null;
        errorMessage = null;

        if (string.IsNullOrWhiteSpace(email) || string.IsNullOrWhiteSpace(token))
        {
            errorMessage = "Invalid reset link.";
            return;
        }

        if (string.IsNullOrWhiteSpace(newPassword) || newPassword.Length < 6)
        {
            errorMessage = "Password must be at least 6 characters.";
            return;
        }

        isSubmitting = true;

        try
        {
            var result = await JS.InvokeAsync<JsonElement>("authFetch", "/api/auth/reset_password",
                new { email, token, newPassword });

            if (!result.GetProperty("ok").GetBoolean())
            {
                string? msg = null;
                if (result.TryGetProperty("data", out var data) && data.ValueKind != JsonValueKind.Null)
                {
                    data.TryGetProperty("message", out var msgEl);
                    msg = msgEl.ValueKind == JsonValueKind.String ? msgEl.GetString() : null;
                }

                errorMessage = string.IsNullOrWhiteSpace(msg) ? "Reset link is invalid or expired." : msg;
                return;
            }

            message = "Password has been reset successfully.";
            await Task.Delay(1000);
            Navigation.NavigateTo("/login?status=password-reset", forceLoad: true);
        }
        catch
        {
            errorMessage = "Unable to reset password right now.";
        }
        finally
        {
            isSubmitting = false;
        }
    }
}
