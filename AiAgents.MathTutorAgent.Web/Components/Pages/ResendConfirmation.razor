@page "/resend-confirmation"
@attribute [AllowAnonymous]
@using System.Text.Json
@inject IJSRuntime JS

<PageTitle>Resend Confirmation - MathTutor AI</PageTitle>

<div class="auth-page">
    <div class="auth-card">
        <h1>Resend Confirmation</h1>
        <p>Enter your email and we'll send a new confirmation link.</p>

        @if (!string.IsNullOrWhiteSpace(message))
        {
            <div class="auth-alert info">@message</div>
        }

        @if (!string.IsNullOrWhiteSpace(errorMessage))
        {
            <div class="auth-alert error">@errorMessage</div>
        }

        <label>
            Email
            <input class="auth-input" type="email" @bind="email" autocomplete="username" />
        </label>

        <button class="auth-btn" @onclick="ResendAsync" disabled="@isSubmitting">
            @(isSubmitting ? "Sending..." : "Send Confirmation Link")
        </button>

        <p class="auth-meta"><a href="/login">Back to login</a></p>
    </div>
</div>

@code {
    private string email = string.Empty;
    private string? message;
    private string? errorMessage;
    private bool isSubmitting;

    private async Task ResendAsync()
    {
        message = null;
        errorMessage = null;

        if (string.IsNullOrWhiteSpace(email))
        {
            errorMessage = "Email is required.";
            return;
        }

        isSubmitting = true;

        try
        {
            var result = await JS.InvokeAsync<JsonElement>("authFetch", "/api/auth/resend-confirmation", new { email });
            string? msg = null;
            if (result.TryGetProperty("data", out var data) && data.ValueKind != JsonValueKind.Null)
            {
                data.TryGetProperty("message", out var msgEl);
                msg = msgEl.ValueKind == JsonValueKind.String ? msgEl.GetString() : null;
            }

            message = string.IsNullOrWhiteSpace(msg)
                ? "If the account exists, a confirmation email has been sent."
                : msg;
        }
        catch
        {
            errorMessage = "Unable to send confirmation email right now.";
        }
        finally
        {
            isSubmitting = false;
        }
    }
}
