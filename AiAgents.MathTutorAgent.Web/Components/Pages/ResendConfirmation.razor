@page "/resend_confirmation"
@attribute [AllowAnonymous]
@using System.Text.Json
@inject IJSRuntime JS
@inject UiPreferencesService UiPrefs
@implements IDisposable

<PageTitle>@($"{L("Ponovo pošalji potvrdu", "Resend Confirmation")} - MathTutor AI")</PageTitle>

<div class="auth-page">
    <div class="auth-card">
        <h1>@L("Ponovo pošalji potvrdu", "Resend Confirmation")</h1>
        <p>@L("Unesi email i poslat ćemo novi link za potvrdu.", "Enter your email and we'll send a new confirmation link.")</p>

        @if (!string.IsNullOrWhiteSpace(message))
        {
            <div class="auth-alert info">@message</div>
        }

        @if (!string.IsNullOrWhiteSpace(errorMessage))
        {
            <div class="auth-alert error">@errorMessage</div>
        }

        <label>
            @L("Email", "Email")
            <input class="auth-input" type="email" @bind="email" autocomplete="username" />
        </label>

        <button class="auth-btn" @onclick="ResendAsync" disabled="@isSubmitting">
            @(isSubmitting ? L("Šaljem...", "Sending...") : L("Pošalji link za potvrdu", "Send Confirmation Link"))
        </button>

        <p class="auth-meta"><a href="/login">@L("Nazad na prijavu", "Back to login")</a></p>
    </div>
</div>

@code {
    private string email = string.Empty;
    private string? message;
    private string? errorMessage;
    private bool isSubmitting;
    private string L(string bs, string en) => UiPrefs.Language == UiLanguage.Bs ? bs : en;

    protected override void OnInitialized()
    {
        UiPrefs.Changed += HandleLanguageChanged;
    }

    private void HandleLanguageChanged()
    {
        _ = InvokeAsync(StateHasChanged);
    }

    private async Task ResendAsync()
    {
        message = null;
        errorMessage = null;

        if (string.IsNullOrWhiteSpace(email))
        {
            errorMessage = L("Email je obavezan.", "Email is required.");
            return;
        }

        isSubmitting = true;

        try
        {
            var result = await JS.InvokeAsync<JsonElement>("authFetch", "/api/auth/resend_confirmation", new { email });
            string? msg = null;
            if (result.TryGetProperty("data", out var data) && data.ValueKind != JsonValueKind.Null)
            {
                data.TryGetProperty("message", out var msgEl);
                msg = msgEl.ValueKind == JsonValueKind.String ? msgEl.GetString() : null;
            }

            message = string.IsNullOrWhiteSpace(msg)
                ? L("Ako nalog postoji, email potvrde je poslan.", "If the account exists, a confirmation email has been sent.")
                : msg;
        }
        catch
        {
            errorMessage = L("Trenutno nije moguće poslati email potvrde.", "Unable to send confirmation email right now.");
        }
        finally
        {
            isSubmitting = false;
        }
    }

    public void Dispose()
    {
        UiPrefs.Changed -= HandleLanguageChanged;
    }
}
