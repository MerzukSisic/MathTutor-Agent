@page "/admin/add-question"
@attribute [Authorize(Roles = UserRoles.Admin)]
@inject HttpClient Http
@inject NavigationManager Navigation
@inject UiPreferencesService UiPrefs

<PageTitle>@($"{L("Dodaj pitanje", "Add Question")} - MathTutor AI")</PageTitle>

<div class="qform-shell">
    <div class="qform-card">
        <div class="qform-header">
            <div>
                <h2>➕ @L("Dodaj novo pitanje", "Add New Question")</h2>
                <p>@L("Kreiraj novi sadržaj za učenike sa mapiranjem teme i težine.", "Create fresh content for students with topic and difficulty mapping.")</p>
            </div>
            <button class="qbtn ghost" @onclick="GoBack">← @L("Nazad", "Back")</button>
        </div>

        @if (!string.IsNullOrWhiteSpace(errorMessage))
        {
            <div class="q-alert error">@errorMessage</div>
        }

        @if (!string.IsNullOrWhiteSpace(successMessage))
        {
            <div class="q-alert success">@successMessage</div>
        }

        <div class="qform-grid">
            <label>
                @L("Tema", "Topic")
                <div class="qselect-wrap">
                    <select class="qinput qselect" @bind="topicId" disabled="@isSubmitting">
                        <option value="0">@L("Odaberi temu", "Select topic")</option>
                        @foreach (var topic in topics)
                        {
                            <option value="@topic.Id">@topic.Name (@topic.Area)</option>
                        }
                    </select>
                </div>
                @if (showTopicError)
                {
                    <span class="q-inline-error">@L("Odaberi temu.", "Please select a topic.")</span>
                }
            </label>

            <label>
                @L("Težina (1-5)", "Difficulty (1-5)")
                <div class="qselect-wrap">
                    <select class="qinput qselect" @bind="difficulty" disabled="@isSubmitting">
                        @for (var i = 1; i <= 5; i++)
                        {
                            <option value="@i">@i</option>
                        }
                    </select>
                </div>
            </label>

            <label class="full">
                @L("Tekst pitanja", "Question text")
                <textarea class="qinput" rows="4" @bind="questionText" disabled="@isSubmitting" placeholder="@L("Primjer: Koliko je 17 + 26?", "Example: What is 17 + 26?")"></textarea>
                @if (showQuestionTextError)
                {
                    <span class="q-inline-error">@L("Tekst pitanja je obavezan.", "Question text is required.")</span>
                }
            </label>

            <label class="full">
                @L("Tačan odgovor", "Correct answer")
                <input class="qinput" @bind="correctAnswer" disabled="@isSubmitting" placeholder="@L("Primjer: 43", "Example: 43")" />
                @if (showCorrectAnswerError)
                {
                    <span class="q-inline-error">@L("Tačan odgovor je obavezan.", "Correct answer is required.")</span>
                }
            </label>

            <label class="full">
                @L("Koraci rješenja (opcionalno)", "Solution steps (optional)")
                <textarea class="qinput" rows="3" @bind="solutionSteps" disabled="@isSubmitting" placeholder="@L("Objašnjenje korak po korak", "Step-by-step explanation")"></textarea>
            </label>

            <label class="full">
                @L("Česte greške (opcionalno, odvojene zarezom)", "Common mistakes (optional, comma separated)")
                <input class="qinput" @bind="commonMistakesRaw" disabled="@isSubmitting" placeholder="42, 44" />
            </label>
        </div>

        <div class="qform-actions">
            <button class="qbtn ghost" @onclick="GoBack" disabled="@isSubmitting">@L("Otkaži", "Cancel")</button>
            <button class="qbtn primary" @onclick="CreateQuestion" disabled="@(isSubmitting || !IsValid())">
                @(isSubmitting ? L("Kreiram...", "Creating...") : L("Kreiraj pitanje", "Create Question"))
            </button>
        </div>
    </div>
</div>

@code {
    private List<TopicDto> topics = new();
    private int topicId;
    private int difficulty = 1;
    private string questionText = string.Empty;
    private string correctAnswer = string.Empty;
    private string? solutionSteps;
    private string commonMistakesRaw = string.Empty;

    private bool isSubmitting;
    private bool showTopicError;
    private bool showQuestionTextError;
    private bool showCorrectAnswerError;
    private string? errorMessage;
    private string? successMessage;
    private string L(string bs, string en) => UiPrefs.Language == UiLanguage.Bs ? bs : en;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            topics = await Http.GetFromJsonAsync<List<TopicDto>>($"/api/admin/topics?lang={UiPrefs.LanguageCode}") ?? new();
        }
        catch
        {
            errorMessage = L("Učitavanje tema nije uspjelo. Osvježi stranicu.", "Failed to load topics. Please refresh.");
        }
    }

    private bool IsValid()
        => topicId > 0 && !string.IsNullOrWhiteSpace(questionText) && !string.IsNullOrWhiteSpace(correctAnswer);

    private bool ValidateForm()
    {
        showTopicError = topicId <= 0;
        showQuestionTextError = string.IsNullOrWhiteSpace(questionText);
        showCorrectAnswerError = string.IsNullOrWhiteSpace(correctAnswer);
        return !showTopicError && !showQuestionTextError && !showCorrectAnswerError;
    }

    private async Task CreateQuestion()
    {
        errorMessage = null;
        successMessage = null;
        showTopicError = false;
        showQuestionTextError = false;
        showCorrectAnswerError = false;

        if (!ValidateForm())
        {
            errorMessage = L("Ispravi greške u formi.", "Please fix validation errors in the form.");
            return;
        }

        isSubmitting = true;

        try
        {
            var dto = new CreateQuestionDto
            {
                TopicId = topicId,
                Difficulty = difficulty,
                QuestionText = questionText.Trim(),
                CorrectAnswer = correctAnswer.Trim(),
                SolutionSteps = string.IsNullOrWhiteSpace(solutionSteps) ? null : solutionSteps.Trim(),
                CommonMistakes = ParseMistakes(commonMistakesRaw)
            };

            var response = await Http.PostAsJsonAsync("/api/admin/questions", dto);
            if (!response.IsSuccessStatusCode)
            {
                errorMessage = $"{L("Kreiranje pitanja nije uspjelo", "Failed to create question")} ({response.StatusCode}).";
                return;
            }

            successMessage = L("Pitanje je uspješno kreirano. Preusmjeravam...", "Question created successfully. Redirecting...");
            await Task.Delay(800);
            Navigation.NavigateTo("/admin?status=question-created");
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
        finally
        {
            isSubmitting = false;
        }
    }

    private static List<string> ParseMistakes(string raw)
        => raw.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries).ToList();

    private void GoBack() => Navigation.NavigateTo("/admin");
}
