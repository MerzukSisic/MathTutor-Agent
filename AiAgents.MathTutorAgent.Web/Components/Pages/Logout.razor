@page "/logout"
@attribute [Authorize]
@using System.Text.Json
@inject IJSRuntime JS
@inject NavigationManager Navigation

<PageTitle>Logout - MathTutor AI</PageTitle>

<div class="auth-page">
    <div class="auth-card">
        <h1>Signing out...</h1>
        <p>Please wait.</p>
    </div>
</div>

@code {
    protected override async Task OnInitializedAsync()
    {
        try
        {
            await JS.InvokeAsync<JsonElement>("authFetch", "/api/auth/logout", new { });
        }
        catch
        {
            // ignore
        }

        Navigation.NavigateTo("/login", forceLoad: true);
    }
}
