@page "/admin"
@using AiAgents.MathTutorAgent.Domain.Entities
@using Radzen
@using Radzen.Blazor
@inject HttpClient Http
@inject NavigationManager Navigation
@rendermode InteractiveServer

<PageTitle>Admin Panel - MathTutor AI</PageTitle>

<RadzenCard>
    <RadzenText TextStyle="TextStyle.H3">👨‍💼 Admin Panel</RadzenText>
</RadzenCard>

<RadzenTabs class="mt-4">
    <Tabs>
        <RadzenTabsItem Text="Performance Metrics">
            <RadzenCard class="mt-3">
                @if (metrics == null)
                {
                    <RadzenProgressBar Mode="ProgressBarMode.Indeterminate" />
                }
                else
                {
                    <RadzenRow Gap="20px">
                        <RadzenColumn Size="12" SizeMD="3">
                            <RadzenCard>
                                <RadzenText TextStyle="TextStyle.H6">Total Students</RadzenText>
                                <RadzenText TextStyle="TextStyle.H3">@metrics.TotalStudents</RadzenText>
                            </RadzenCard>
                        </RadzenColumn>
                        <RadzenColumn Size="12" SizeMD="3">
                            <RadzenCard>
                                <RadzenText TextStyle="TextStyle.H6">Total Questions</RadzenText>
                                <RadzenText TextStyle="TextStyle.H3">@metrics.TotalQuestions</RadzenText>
                            </RadzenCard>
                        </RadzenColumn>
                        <RadzenColumn Size="12" SizeMD="3">
                            <RadzenCard>
                                <RadzenText TextStyle="TextStyle.H6">Total Attempts</RadzenText>
                                <RadzenText TextStyle="TextStyle.H3">@metrics.TotalAttempts</RadzenText>
                            </RadzenCard>
                        </RadzenColumn>
                        <RadzenColumn Size="12" SizeMD="3">
                            <RadzenCard>
                                <RadzenText TextStyle="TextStyle.H6">Success Rate</RadzenText>
                                <RadzenText TextStyle="TextStyle.H3">@metrics.SuccessRate.ToString("F1")%</RadzenText>
                            </RadzenCard>
                        </RadzenColumn>
                    </RadzenRow>

                    <RadzenCard class="mt-4">
                        <RadzenText TextStyle="TextStyle.H6">Agent Performance</RadzenText>
                        <RadzenText>Completed Work Items: @metrics.CompletedWorkItems / @metrics.TotalWorkItems</RadzenText>
                        <RadzenText>Average Processing Time: @metrics.AverageProcessingTimeMs.ToString("F0") ms</RadzenText>
                    </RadzenCard>
                }
            </RadzenCard>
        </RadzenTabsItem>

        <RadzenTabsItem Text="Questions">
            <RadzenCard class="mt-3">
                <RadzenButton Text="Add New Question" Click="OpenAddQuestionDialog" ButtonStyle="ButtonStyle.Success" Icon="add" class="mb-3" />

                @if (questions == null)
                {
                    <RadzenProgressBar Mode="ProgressBarMode.Indeterminate" />
                }
                else
                {
                    <RadzenDataGrid Data="@questions" TItem="QuestionDto" AllowFiltering="true" AllowSorting="true" AllowPaging="true" PageSize="10">
                        <Columns>
                            <RadzenDataGridColumn TItem="QuestionDto" Property="Id" Title="ID" Width="60px" />
                            <RadzenDataGridColumn TItem="QuestionDto" Property="TopicName" Title="Topic" />
                            <RadzenDataGridColumn TItem="QuestionDto" Property="Difficulty" Title="Difficulty" Width="100px" />
                            <RadzenDataGridColumn TItem="QuestionDto" Property="QuestionText" Title="Question" />
                            <RadzenDataGridColumn TItem="QuestionDto" Property="CorrectAnswer" Title="Answer" Width="150px" />
                            <RadzenDataGridColumn TItem="QuestionDto" Title="Actions" Width="120px">
                                <Template Context="question">
                                    <RadzenButton Icon="edit" ButtonStyle="ButtonStyle.Light" Size="ButtonSize.Small" Click="@(() => EditQuestion(question))" />
                                    <RadzenButton Icon="delete" ButtonStyle="ButtonStyle.Danger" Size="ButtonSize.Small" Click="@(() => DeleteQuestion(question.Id))" class="ms-1" />
                                </Template>
                            </RadzenDataGridColumn>
                        </Columns>
                    </RadzenDataGrid>
                }
            </RadzenCard>
        </RadzenTabsItem>

        <RadzenTabsItem Text="Students">
            <RadzenCard class="mt-3">
                @if (students == null)
                {
                    <RadzenProgressBar Mode="ProgressBarMode.Indeterminate" />
                }
                else
                {
                    <RadzenDataGrid Data="@students" TItem="StudentDto" AllowFiltering="true" AllowSorting="true" AllowPaging="true" PageSize="10">
                        <Columns>
                            <RadzenDataGridColumn TItem="StudentDto" Property="Id" Title="ID" Width="60px" />
                            <RadzenDataGridColumn TItem="StudentDto" Property="Name" Title="Name" />
                            <RadzenDataGridColumn TItem="StudentDto" Property="Email" Title="Email" />
                            <RadzenDataGridColumn TItem="StudentDto" Property="TotalAttempts" Title="Total Attempts" Width="130px" />
                            <RadzenDataGridColumn TItem="StudentDto" Property="CorrectAttempts" Title="Correct" Width="100px" />
                            <RadzenDataGridColumn TItem="StudentDto" Title="Actions" Width="100px">
                                <Template Context="student">
                                    <RadzenButton Text="Profile" ButtonStyle="ButtonStyle.Info" Size="ButtonSize.Small" Click="@(() => ViewProfile(student.Id))" />
                                </Template>
                            </RadzenDataGridColumn>
                        </Columns>
                    </RadzenDataGrid>
                }
            </RadzenCard>
        </RadzenTabsItem>
    </Tabs>
</RadzenTabs>

@code {
    private PerformanceMetricsDto? metrics;
    private List<QuestionDto>? questions;
    private List<StudentDto>? students;

    protected override async Task OnInitializedAsync()
    {
        await LoadMetrics();
        await LoadQuestions();
        await LoadStudents();
    }

    private async Task LoadMetrics()
    {
        metrics = await Http.GetFromJsonAsync<PerformanceMetricsDto>("/api/admin/performance-metrics");
    }

    private async Task LoadQuestions()
    {
        questions = await Http.GetFromJsonAsync<List<QuestionDto>>("/api/admin/questions");
    }

    private async Task LoadStudents()
    {
        students = await Http.GetFromJsonAsync<List<StudentDto>>("/api/admin/students");
    }

    private void OpenAddQuestionDialog()
    {
        // TODO: Implement dialog
    }

    private void EditQuestion(QuestionDto question)
    {
        // TODO: Implement edit dialog
    }

    private async Task DeleteQuestion(int id)
    {
        var response = await Http.DeleteAsync($"/api/admin/questions/{id}");
        if (response.IsSuccessStatusCode)
        {
            await LoadQuestions();
        }
    }

    private void ViewProfile(int studentId)
    {
        Navigation.NavigateTo($"/profile/{studentId}");
    }

    private class PerformanceMetricsDto
    {
        public int TotalStudents { get; set; }
        public int TotalQuestions { get; set; }
        public int TotalAttempts { get; set; }
        public int TotalWorkItems { get; set; }
        public int CompletedWorkItems { get; set; }
        public double AverageProcessingTimeMs { get; set; }
        public double SuccessRate { get; set; }
    }

    private class QuestionDto
    {
        public int Id { get; set; }
        public int TopicId { get; set; }
        public string TopicName { get; set; } = string.Empty;
        public int Difficulty { get; set; }
        public string QuestionText { get; set; } = string.Empty;
        public string CorrectAnswer { get; set; } = string.Empty;
        public string? SolutionSteps { get; set; }
    }

    private class StudentDto
    {
        public int Id { get; set; }
        public string Name { get; set; } = string.Empty;
        public string Email { get; set; } = string.Empty;
        public DateTime CreatedAt { get; set; }
        public int TotalAttempts { get; set; }
        public int CorrectAttempts { get; set; }
    }
}