@page "/login"
@attribute [AllowAnonymous]
@using Microsoft.AspNetCore.WebUtilities
@using System.Text.Json
@inject IJSRuntime JS
@inject NavigationManager Navigation
@inject UiPreferencesService UiPrefs
@inject NotificationService Notifications
@implements IDisposable

<PageTitle>@($"{L("Prijava", "Login")} - MathTutor AI")</PageTitle>

<div class="auth-page">
    <div class="auth-card">
        <h1>@L("Prijava", "Sign In")</h1>
        <p>@L("Nastavi svoje MathTutor učenje.", "Continue your MathTutor learning journey.")</p>

        <label>
            @L("Email", "Email")
            <input class="auth-input" type="email" @bind="email" autocomplete="username" />
        </label>

        <label>
            @L("Lozinka", "Password")
            <div class="auth-password-wrap">
                <input class="auth-input" type="@(showPassword ? "text" : "password")" @bind="password" autocomplete="current-password" />
                <button type="button"
                        class="auth-password-toggle"
                        @onclick="TogglePasswordVisibility"
                        aria-label="@(showPassword ? L("Sakrij lozinku", "Hide password") : L("Prikaži lozinku", "Show password"))"
                        aria-pressed="@showPassword">
                    @(showPassword ? L("Sakrij", "Hide") : L("Prikaži", "Show"))
                </button>
            </div>
        </label>

        <button class="auth-btn" @onclick="LoginAsync" disabled="@isSubmitting">
            @(isSubmitting ? L("Prijavljujem...", "Signing in...") : L("Prijavi se", "Sign In"))
        </button>

        <p class="auth-meta">@L("Nemaš nalog?", "No account yet?") <a href="/register">@L("Napravi ga", "Create one")</a></p>
        <p class="auth-meta"><a href="/forgot_password">@L("Zaboravljena lozinka?", "Forgot password?")</a></p>
    </div>
</div>

@code {
    private string email = string.Empty;
    private string password = string.Empty;
    private bool isSubmitting;
    private bool showPassword;
    private string L(string bs, string en) => UiPrefs.Language == UiLanguage.Bs ? bs : en;

    protected override void OnInitialized()
    {
        UiPrefs.Changed += HandleLanguageChanged;

        var uri = Navigation.ToAbsoluteUri(Navigation.Uri);
        var query = QueryHelpers.ParseQuery(uri.Query);
        if (!query.TryGetValue("status", out var statusValue))
        {
            return;
        }

        switch (statusValue.ToString())
        {
            case "registered":
                NotifyInfo(L("Registracija uspješna. Potvrdi email prije prijave.", "Registration successful. Please confirm your email before signing in."));
                break;
            case "registered-ready":
                NotifyInfo(L("Registracija uspješna. Sada se možeš prijaviti.", "Registration successful. You can sign in now."));
                break;
            case "confirmed":
                NotifyInfo(L("Email je uspješno potvrđen. Sada se možeš prijaviti.", "Email confirmed successfully. You can now sign in."));
                break;
            case "password-reset":
                NotifyInfo(L("Lozinka je uspješno promijenjena. Prijavi se novom lozinkom.", "Password changed successfully. Sign in with your new password."));
                break;
        }
    }

    private void HandleLanguageChanged()
    {
        _ = InvokeAsync(StateHasChanged);
    }

    private void TogglePasswordVisibility()
    {
        showPassword = !showPassword;
    }

    private async Task LoginAsync()
    {
        if (string.IsNullOrWhiteSpace(email) || string.IsNullOrWhiteSpace(password))
        {
            NotifyWarning(L("Unesi i email i lozinku.", "Please enter both email and password."));
            return;
        }

        isSubmitting = true;

        try
        {
            var result = await JS.InvokeAsync<JsonElement>("authFetch", "/api/auth/login",
                new { email, password });

            var ok = result.GetProperty("ok").GetBoolean();
            if (!ok)
            {
                string? msg = null;
                if (result.TryGetProperty("data", out var data) && data.ValueKind != JsonValueKind.Null)
                {
                    data.TryGetProperty("message", out var msgEl);
                    msg = msgEl.ValueKind == JsonValueKind.String ? msgEl.GetString() : null;
                }
                var errorMessage = string.IsNullOrWhiteSpace(msg) ? L("Neispravan email ili lozinka.", "Invalid email or password.") : msg;
                NotifyError(errorMessage);
                return;
            }

            AuthUserDto? user = null;
            if (result.TryGetProperty("data", out var authData) && authData.ValueKind != JsonValueKind.Null
                && authData.TryGetProperty("user", out var userEl) && userEl.ValueKind != JsonValueKind.Null)
            {
                user = JsonSerializer.Deserialize<AuthUserDto>(userEl.GetRawText(),
                    new JsonSerializerOptions { PropertyNameCaseInsensitive = true });
            }

            var returnUrl = GetReturnUrl();
            var destination = string.IsNullOrWhiteSpace(returnUrl) ? GetDefaultRoute(user) : returnUrl;
            Navigation.NavigateTo(destination, forceLoad: true);
        }
        catch
        {
            NotifyError(L("Prijava nije uspjela. Pokušaj ponovo.", "Login failed. Please try again."));
        }
        finally
        {
            isSubmitting = false;
        }
    }

    private string GetReturnUrl()
    {
        var uri = Navigation.ToAbsoluteUri(Navigation.Uri);
        var query = QueryHelpers.ParseQuery(uri.Query);
        if (query.TryGetValue("returnUrl", out var returnUrl) && !string.IsNullOrWhiteSpace(returnUrl))
        {
            var value = returnUrl.ToString();
            if (value.StartsWith('/') && !value.StartsWith("//"))
            {
                return value;
            }
        }

        return string.Empty;
    }

    private static string GetDefaultRoute(AuthUserDto? user)
    {
        if (user == null)
        {
            return "/";
        }

        if (string.Equals(user.Role, UserRoles.Admin, StringComparison.OrdinalIgnoreCase))
        {
            return "/";
        }

        return user.StudentId.HasValue ? $"/quiz/{user.StudentId.Value}" : "/";
    }

    public void Dispose()
    {
        UiPrefs.Changed -= HandleLanguageChanged;
    }

    private void NotifyInfo(string detail)
        => Notifications.Notify(NotificationSeverity.Info, L("Info", "Info"), detail, 5000);

    private void NotifyWarning(string detail)
        => Notifications.Notify(NotificationSeverity.Warning, L("Provjeri unos", "Check input"), detail, 5000);

    private void NotifyError(string detail)
        => Notifications.Notify(NotificationSeverity.Error, L("Neuspješno", "Failed"), detail, 6500);
}
