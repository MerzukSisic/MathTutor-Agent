@page "/"
@attribute [Authorize(Roles = UserRoles.Admin)]
@inject HttpClient Http
@inject NavigationManager Navigation

<PageTitle>Dashboard - MathTutor AI</PageTitle>

<div class="dashboard">
    <!-- Welcome Section -->
    <div class="welcome-card">
        <div class="welcome-content">
            <h2>Welcome to MathTutor AI</h2>
            <p>Track your learning progress and master mathematics step by step</p>
        </div>
        <button class="btn-primary" @onclick="StartNewQuiz">
            <span class="btn-icon">🚀</span>
            Start Learning
        </button>
    </div>

    <!-- Students Grid -->
    <div class="students-section">
        <div class="section-header">
            <h3>Select Student</h3>
            <div class="section-actions">
                <input class="student-search" @bind="studentFilter" @bind:event="oninput" placeholder="Search student..." />
                <button class="btn-secondary" @onclick="RefreshAll">
                    <span>🔄</span>
                    Refresh
                </button>
            </div>
        </div>

        @if (isLoading)
        {
            <div class="loading-state">
                <div class="spinner"></div>
                <p>Loading students...</p>
            </div>
        }
        else if (FilteredStudents.Any())
        {
            <p class="students-meta">Showing @FilteredStudents.Count / @(students?.Count ?? 0) students</p>
            <div class="students-grid">
                @foreach (var student in FilteredStudents)
                {
                    <div class="student-card" @onclick="() => ViewStudentProfile(student.Id)">
                        <div class="student-avatar">
                            @GetInitials(student.Name)
                        </div>
                        <div class="student-info">
                            <h4>@student.Name</h4>
                            <p class="student-email">@student.Email</p>
                            <p class="student-date">Member since @student.CreatedAt.ToString("MMM dd, yyyy")</p>
                        </div>
                        <div class="student-actions">
                            <button class="btn-action" @onclick:stopPropagation="true" @onclick="() => StartQuizForStudent(student.Id)">
                                Start Quiz
                            </button>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="empty-state">
                <span class="empty-icon">👥</span>
                <p>No students found</p>
                <button class="btn-secondary" @onclick="OpenAddStudentDialog">Add Students</button>
            </div>
        }
    </div>

    <!-- Quick Stats -->
    <div class="stats-grid">
        <div class="stat-card">
            <div class="stat-icon">📚</div>
            <div class="stat-content">
                <p class="stat-label">Total Students</p>
                <p class="stat-value">@(dashboardStats?.TotalStudents ?? 0)</p>
            </div>
        </div>
        
        <div class="stat-card">
            <div class="stat-icon">✅</div>
            <div class="stat-content">
                <p class="stat-label">Active Sessions</p>
                <p class="stat-value">@(dashboardStats?.ActiveSessions ?? 0)</p>
            </div>
        </div>
        
        <div class="stat-card">
            <div class="stat-icon">🎯</div>
            <div class="stat-content">
                <p class="stat-label">Questions Completed</p>
                <p class="stat-value">@(dashboardStats?.QuestionsCompleted ?? 0)</p>
            </div>
        </div>
        
        <div class="stat-card">
            <div class="stat-icon">⚡</div>
            <div class="stat-content">
                <p class="stat-label">Agent Status</p>
                <p class="stat-value @GetStatusClass()">
                    @(dashboardStats?.AgentStatus ?? "Loading...")
                </p>
            </div>
        </div>
    </div>
</div>

@code {
    private List<StudentDto>? students;
    private DashboardStatsDto? dashboardStats;
    private bool isLoading = true;
    private string studentFilter = string.Empty;

    private List<StudentDto> FilteredStudents
        => students?
            .Where(s => string.IsNullOrWhiteSpace(studentFilter)
                || s.Name.Contains(studentFilter, StringComparison.OrdinalIgnoreCase)
                || s.Email.Contains(studentFilter, StringComparison.OrdinalIgnoreCase))
            .ToList()
            ?? new List<StudentDto>();

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        try
        {
            isLoading = true;
            
            // Load both students and stats in parallel
            var studentsTask = Http.GetFromJsonAsync<List<StudentDto>>("/api/admin/students");
            var statsTask = Http.GetFromJsonAsync<DashboardStatsDto>("/api/admin/dashboard/stats");
            
            await Task.WhenAll(studentsTask, statsTask);
            
            students = await studentsTask;
            dashboardStats = await statsTask;
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading data: {ex.Message}");
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task RefreshAll()
    {
        await LoadData();
    }

    private void StartNewQuiz()
    {
        if (students?.Any() == true)
        {
            Navigation.NavigateTo($"/quiz/{students.First().Id}");
        }
    }

    private void StartQuizForStudent(int studentId)
    {
        Navigation.NavigateTo($"/quiz/{studentId}");
    }

    private void ViewStudentProfile(int studentId)
    {
        Navigation.NavigateTo($"/profile/{studentId}");
    }

    private string GetInitials(string name)
    {
        var parts = name.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        if (parts.Length >= 2)
            return $"{parts[0][0]}{parts[1][0]}".ToUpper();
        return parts.Length > 0 ? parts[0][..Math.Min(2, parts[0].Length)].ToUpper() : "??";
    }
    
    private void OpenAddStudentDialog()
    {
        Navigation.NavigateTo("/admin/add-student");
    }

    private string GetStatusClass()
    {
        return dashboardStats?.AgentStatus switch
        {
            "Processing" => "status-processing",
            "Online" => "status-online",
            _ => "status-offline"
        };
    }
}
