@page "/"
@attribute [Authorize(Roles = UserRoles.Admin)]
@inject HttpClient Http
@inject NavigationManager Navigation
@inject UiPreferencesService UiPrefs
@using System.Globalization
@implements IDisposable

<PageTitle>@($"{UiPrefs.T("dashboard")} - {UiPrefs.T("app_name")}")</PageTitle>

<div class="dashboard">
    <div class="welcome-card">
        <div class="welcome-content">
            <h2>@UiPrefs.T("welcome_title")</h2>
            <p>@UiPrefs.T("welcome_subtitle")</p>
        </div>
        <button class="btn-primary" @onclick="StartNewQuiz" disabled="@(!CanStartAnyQuiz)">
            <span class="btn-icon">🚀</span>
            @UiPrefs.T("start_learning")
        </button>
    </div>

    <div class="students-section">
        <div class="section-header">
            <h3>@UiPrefs.T("select_student")</h3>
            <div class="section-actions">
                <input class="student-search" @bind="studentFilter" @bind:event="oninput" placeholder="@UiPrefs.T("search_student")" />
                <button class="btn-secondary" @onclick="RefreshAll">
                    <span>🔄</span>
                    @UiPrefs.T("refresh")
                </button>
            </div>
        </div>

        @if (isLoading)
        {
            <div class="loading-state">
                <div class="spinner"></div>
                <p>@UiPrefs.T("loading_students")</p>
            </div>
        }
        else if (FilteredStudents.Any())
        {
            <p class="students-meta">@UiPrefs.T("showing_students", FilteredStudents.Count, students?.Count ?? 0)</p>
            <div class="students-grid">
                @foreach (var student in FilteredStudents)
                {
                    <div class="student-card" @onclick="() => ViewStudentProfile(student.Id)">
                        <div class="student-avatar">
                            @GetInitials(student.Name)
                        </div>
                        <div class="student-info">
                            <h4>@student.Name</h4>
                            <p class="student-email">@student.Email</p>
                            <p class="student-date">@UiPrefs.T("member_since", FormatMemberSince(student.CreatedAt))</p>
                        </div>
                        <div class="student-actions">
                            <button class="btn-action" @onclick:stopPropagation="true" @onclick="() => StartQuizForStudent(student.Id)">
                                @UiPrefs.T("start_quiz")
                            </button>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="empty-state">
                <span class="empty-icon">👥</span>
                <p>@UiPrefs.T("no_students_found")</p>
                <button class="btn-secondary" @onclick="OpenAddStudentDialog">@UiPrefs.T("add_students")</button>
            </div>
        }
    </div>

    <div class="stats-grid">
        <div class="stat-card">
            <div class="stat-icon">📚</div>
            <div class="stat-content">
                <p class="stat-label">@UiPrefs.T("total_students")</p>
                <p class="stat-value">@(dashboardStats?.TotalStudents ?? 0)</p>
            </div>
        </div>

        <div class="stat-card">
            <div class="stat-icon">✅</div>
            <div class="stat-content">
                <p class="stat-label">@UiPrefs.T("active_sessions")</p>
                <p class="stat-value">@(dashboardStats?.ActiveSessions ?? 0)</p>
            </div>
        </div>

        <div class="stat-card">
            <div class="stat-icon">🎯</div>
            <div class="stat-content">
                <p class="stat-label">@UiPrefs.T("questions_completed")</p>
                <p class="stat-value">@(dashboardStats?.QuestionsCompleted ?? 0)</p>
            </div>
        </div>

        <div class="stat-card">
            <div class="stat-icon">⚡</div>
            <div class="stat-content">
                <p class="stat-label">@UiPrefs.T("agent_status")</p>
                <p class="stat-value @GetStatusClass()">
                    @GetStatusLabel()
                </p>
            </div>
        </div>
    </div>
</div>

@code {
    private List<StudentDto>? students;
    private DashboardStatsDto? dashboardStats;
    private bool isLoading = true;
    private string studentFilter = string.Empty;

    private bool CanStartAnyQuiz => students?.Any() == true;

    private List<StudentDto> FilteredStudents
        => students?
            .Where(s => string.IsNullOrWhiteSpace(studentFilter)
                || s.Name.Contains(studentFilter, StringComparison.OrdinalIgnoreCase)
                || s.Email.Contains(studentFilter, StringComparison.OrdinalIgnoreCase))
            .ToList()
            ?? new List<StudentDto>();

    protected override void OnInitialized()
    {
        UiPrefs.Changed += HandleLanguageChanged;
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private void HandleLanguageChanged()
    {
        _ = InvokeAsync(StateHasChanged);
    }

    private async Task LoadData()
    {
        try
        {
            isLoading = true;

            var studentsTask = Http.GetFromJsonAsync<List<StudentDto>>("/api/admin/students");
            var statsTask = Http.GetFromJsonAsync<DashboardStatsDto>("/api/admin/dashboard/stats");

            await Task.WhenAll(studentsTask, statsTask);

            students = await studentsTask;
            dashboardStats = await statsTask;
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading data: {ex.Message}");
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task RefreshAll()
    {
        await LoadData();
    }

    private void StartNewQuiz()
    {
        if (students?.Any() == true)
        {
            Navigation.NavigateTo($"/quiz/{students.First().Id}");
        }
    }

    private void StartQuizForStudent(int studentId)
    {
        Navigation.NavigateTo($"/quiz/{studentId}");
    }

    private void ViewStudentProfile(int studentId)
    {
        Navigation.NavigateTo($"/profile/{studentId}");
    }

    private string GetInitials(string name)
    {
        var parts = name.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        if (parts.Length >= 2)
            return $"{parts[0][0]}{parts[1][0]}".ToUpperInvariant();

        return parts.Length > 0
            ? parts[0][..Math.Min(2, parts[0].Length)].ToUpperInvariant()
            : "??";
    }

    private void OpenAddStudentDialog()
    {
        Navigation.NavigateTo("/admin/add-student");
    }

    private string GetStatusClass()
    {
        if (string.Equals(dashboardStats?.AgentStatus, "Processing", StringComparison.OrdinalIgnoreCase))
        {
            return "status-processing";
        }

        if (string.Equals(dashboardStats?.AgentStatus, "Online", StringComparison.OrdinalIgnoreCase))
        {
            return "status-online";
        }

        return "status-offline";
    }

    private string GetStatusLabel()
    {
        if (isLoading)
        {
            return UiPrefs.T("loading");
        }

        if (string.Equals(dashboardStats?.AgentStatus, "Processing", StringComparison.OrdinalIgnoreCase))
        {
            return UiPrefs.T("status_processing");
        }

        if (string.Equals(dashboardStats?.AgentStatus, "Online", StringComparison.OrdinalIgnoreCase))
        {
            return UiPrefs.T("status_online");
        }

        return UiPrefs.T("status_offline");
    }

    private string FormatMemberSince(DateTime createdAt)
    {
        var culture = UiPrefs.Language == UiLanguage.Bs
            ? CultureInfo.GetCultureInfo("bs-BA")
            : CultureInfo.GetCultureInfo("en-US");

        return createdAt.ToString("dd MMM yyyy", culture);
    }

    public void Dispose()
    {
        UiPrefs.Changed -= HandleLanguageChanged;
    }
}
