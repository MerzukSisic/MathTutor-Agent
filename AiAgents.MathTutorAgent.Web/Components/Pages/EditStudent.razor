@page "/admin/edit-student/{id:int}"
@attribute [Authorize(Roles = UserRoles.Admin)]
@inject HttpClient Http
@inject NavigationManager Navigation
@inject UiPreferencesService UiPrefs
@inject NotificationService Notifications
@implements IDisposable

<PageTitle>@($"{L("Uredi učenika", "Edit Student")} - MathTutor AI")</PageTitle>

<div class="qform-shell">
    <div class="qform-card">
        <div class="qform-header">
            <div>
                <h2>✏️ @L("Uredi učenika", "Edit Student")</h2>
                <p>@L("Sigurno ažuriraj identitet učenika i email naloga.", "Update student identity and account email safely.")</p>
            </div>
            <button class="qbtn ghost" @onclick="GoBack">← @L("Nazad", "Back")</button>
        </div>

        @if (isLoading)
        {
            <div class="q-loading">@L("Učitavam učenika...", "Loading student...")</div>
        }
        else
        {
            <div class="qform-grid">
                <label>
                    @L("Puno ime", "Full name")
                    <input class="qinput" @bind="name" disabled="@isSubmitting" />
                </label>

                <label>
                    @L("Email", "Email")
                    <input class="qinput" type="email" @bind="email" disabled="@isSubmitting" />
                </label>
            </div>

            <div class="qform-actions">
                <button class="qbtn ghost" @onclick="GoBack" disabled="@isSubmitting">@L("Otkaži", "Cancel")</button>
                <button class="qbtn primary" @onclick="UpdateStudent" disabled="@(isSubmitting || !IsValid())">
                    @(isSubmitting ? L("Spremam...", "Saving...") : L("Spremi izmjene", "Save Changes"))
                </button>
            </div>
        }
    </div>
</div>

@code {
    [Parameter] public int Id { get; set; }

    private string name = string.Empty;
    private string email = string.Empty;
    private bool isLoading = true;
    private bool isSubmitting;
    private string L(string bs, string en) => UiPrefs.Language == UiLanguage.Bs ? bs : en;

    protected override void OnInitialized()
    {
        UiPrefs.Changed += HandleLanguageChanged;
    }

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var student = await Http.GetFromJsonAsync<StudentDto>($"/api/admin/students/{Id}");
            if (student == null)
            {
                NotifyError(L("Učenik nije pronađen.", "Student not found."));
                return;
            }

            name = student.Name;
            email = student.Email;
        }
        catch (HttpRequestException ex)
        {
            NotifyError($"{L("Ne mogu učitati učenika", "Unable to load student")} ({ex.Message}).");
        }
        finally
        {
            isLoading = false;
        }
    }

    private void HandleLanguageChanged()
    {
        _ = InvokeAsync(StateHasChanged);
    }

    private bool IsValid()
        => !string.IsNullOrWhiteSpace(name) && !string.IsNullOrWhiteSpace(email) && email.Contains('@');

    private async Task UpdateStudent()
    {
        if (!IsValid())
        {
            NotifyWarning(L("Unesi ispravno ime učenika i email.", "Please enter valid student name and email."));
            return;
        }

        isSubmitting = true;

        try
        {
            var payload = new UpdateStudentDto
            {
                Name = name.Trim(),
                Email = email.Trim()
            };

            var response = await Http.PutAsJsonAsync($"/api/admin/students/{Id}", payload);
            if (!response.IsSuccessStatusCode)
            {
                var error = await response.Content.ReadAsStringAsync();
                var errorMessage = string.IsNullOrWhiteSpace(error)
                    ? $"{L("Ažuriranje nije uspjelo", "Update failed")} ({response.StatusCode})."
                    : ExtractApiErrorMessage(error);
                NotifyError(errorMessage);
                return;
            }

            NotifySuccess(L("Uspješno ste editovali učenika.", "You successfully edited the student."));
            await Task.Delay(800);
            Navigation.NavigateTo("/admin?status=student-updated");
        }
        catch (Exception ex)
        {
            NotifyError(ex.Message);
        }
        finally
        {
            isSubmitting = false;
        }
    }

    private void GoBack() => Navigation.NavigateTo("/admin");

    private static string ExtractApiErrorMessage(string raw)
    {
        try
        {
            using var doc = System.Text.Json.JsonDocument.Parse(raw);
            if (doc.RootElement.TryGetProperty("message", out var msgElement) &&
                msgElement.ValueKind == System.Text.Json.JsonValueKind.String)
            {
                return msgElement.GetString() ?? raw;
            }
        }
        catch
        {
            // ignore parse errors
        }

        return raw;
    }

    public void Dispose()
    {
        UiPrefs.Changed -= HandleLanguageChanged;
    }

    private void NotifySuccess(string detail)
        => Notifications.Notify(NotificationSeverity.Success, L("Uspješno", "Success"), detail, 4500);

    private void NotifyWarning(string detail)
        => Notifications.Notify(NotificationSeverity.Warning, L("Provjeri unos", "Check input"), detail, 4500);

    private void NotifyError(string detail)
        => Notifications.Notify(NotificationSeverity.Error, L("Neuspješno", "Failed"), detail, 6000);
}
