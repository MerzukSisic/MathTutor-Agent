@page "/admin/add-student"
@attribute [Authorize(Roles = UserRoles.Admin)]
@using AiAgents.MathTutorAgent.Application.DTOs
@inject HttpClient Http
@inject NavigationManager Navigation
@rendermode InteractiveServer

<PageTitle>Add Student - MathTutor AI</PageTitle>

<div class="qform-shell">
    <div class="qform-card">
        <div class="qform-header">
            <div>
                <h2>➕ Add New Student</h2>
                <p>Create a student profile and connect it to login account flow.</p>
            </div>
            <button class="qbtn ghost" @onclick="GoBack">
                ← Back
            </button>
        </div>

        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="q-alert error">
                @errorMessage
            </div>
        }

        @if (!string.IsNullOrEmpty(successMessage))
        {
            <div class="q-alert success">
                @successMessage
            </div>
        }

        <div class="qform-grid">
            <label class="full" for="name">
                Student name
                <input
                    id="name"
                    type="text"
                    class="qinput"
                    @bind="name"
                    placeholder="Enter full name"
                    disabled="@isSubmitting" />
                @if (showNameError)
                {
                    <span class="q-inline-error">Name is required.</span>
                }
            </label>

            <label class="full" for="email">
                Email address
                <input
                    id="email"
                    type="email"
                    class="qinput"
                    @bind="email"
                    placeholder="student@example.com"
                    disabled="@isSubmitting" />
                @if (showEmailError)
                {
                    <span class="q-inline-error">Valid email is required.</span>
                }
            </label>
        </div>

        <div class="qform-actions">
            <button
                    class="qbtn ghost"
                    @onclick="GoBack"
                    disabled="@isSubmitting">
                    Cancel
                </button>
                <button
                    class="qbtn primary"
                    @onclick="CreateStudent"
                    disabled="@(isSubmitting || !IsValid())">
                    @(isSubmitting ? "Creating..." : "Create Student")
                </button>
        </div>
    </div>
</div>

@code {
    private string name = string.Empty;
    private string email = string.Empty;
    private bool isSubmitting = false;
    private bool showNameError = false;
    private bool showEmailError = false;
    private string errorMessage = string.Empty;
    private string successMessage = string.Empty;

    private bool IsValid()
    {
        return !string.IsNullOrWhiteSpace(name) && !string.IsNullOrWhiteSpace(email) && email.Contains("@");
    }

    private async Task CreateStudent()
    {
        // Reset errors
        showNameError = false;
        showEmailError = false;
        errorMessage = string.Empty;
        successMessage = string.Empty;

        // Validate
        if (string.IsNullOrWhiteSpace(name))
        {
            showNameError = true;
            return;
        }

        if (string.IsNullOrWhiteSpace(email) || !email.Contains("@"))
        {
            showEmailError = true;
            return;
        }

        isSubmitting = true;

        try
        {
            var request = new CreateStudentDto { Name = name.Trim(), Email = email.Trim() };
            var response = await Http.PostAsJsonAsync("/api/admin/students", request);
            
            if (response.IsSuccessStatusCode)
            {
                successMessage = "Student created successfully! Redirecting...";
                await Task.Delay(900);
                Navigation.NavigateTo("/admin?status=student-created");
            }
            else
            {
                var errorContent = await response.Content.ReadAsStringAsync();
                errorMessage = string.IsNullOrWhiteSpace(errorContent)
                    ? $"Failed to create student ({response.StatusCode})."
                    : ExtractApiErrorMessage(errorContent);
                Console.WriteLine($"Error: {errorContent}");
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Error: {ex.Message}";
            Console.WriteLine($"Exception: {ex}");
        }
        finally
        {
            isSubmitting = false;
        }
    }

    private void GoBack()
    {
        Navigation.NavigateTo("/admin");
    }

    private static string ExtractApiErrorMessage(string raw)
    {
        try
        {
            using var doc = System.Text.Json.JsonDocument.Parse(raw);
            if (doc.RootElement.TryGetProperty("message", out var msgElement) &&
                msgElement.ValueKind == System.Text.Json.JsonValueKind.String)
            {
                return msgElement.GetString() ?? raw;
            }
        }
        catch
        {
            // ignore parse errors
        }

        return raw;
    }
}
