@page "/admin/add-student"
@attribute [Authorize(Roles = UserRoles.Admin)]
@using AiAgents.MathTutorAgent.Application.DTOs
@inject HttpClient Http
@inject NavigationManager Navigation
@rendermode InteractiveServer

<PageTitle>Add Student - MathTutor AI</PageTitle>

<div class="add-student-container">
    <div class="add-student-card">
        <div class="card-header">
            <h2>➕ Add New Student</h2>
            <button class="btn-back" @onclick="GoBack">
                ← Back to Admin
            </button>
        </div>

        <div class="form-section">
            <div class="form-group">
                <label for="name">Student Name</label>
                <input 
                    id="name"
                    type="text" 
                    class="form-input" 
                    @bind="name" 
                    placeholder="Enter full name"
                    disabled="@isSubmitting" />
                @if (showNameError)
                {
                    <span class="error-text">Name is required</span>
                }
            </div>

            <div class="form-group">
                <label for="email">Email Address</label>
                <input 
                    id="email"
                    type="email" 
                    class="form-input" 
                    @bind="email" 
                    placeholder="student@example.com"
                    disabled="@isSubmitting" />
                @if (showEmailError)
                {
                    <span class="error-text">Valid email is required</span>
                }
            </div>

            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <div class="alert alert-danger">
                    ❌ @errorMessage
                </div>
            }

            @if (!string.IsNullOrEmpty(successMessage))
            {
                <div class="alert alert-success">
                    ✅ @successMessage
                </div>
            }

            <div class="form-actions">
                <button 
                    class="btn-cancel" 
                    @onclick="GoBack"
                    disabled="@isSubmitting">
                    Cancel
                </button>
                <button 
                    class="btn-submit" 
                    @onclick="CreateStudent"
                    disabled="@(isSubmitting || !IsValid())">
                    @(isSubmitting ? "Creating..." : "Create Student")
                </button>
            </div>
        </div>
    </div>
</div>

@code {
    private string name = string.Empty;
    private string email = string.Empty;
    private bool isSubmitting = false;
    private bool showNameError = false;
    private bool showEmailError = false;
    private string errorMessage = string.Empty;
    private string successMessage = string.Empty;

    private bool IsValid()
    {
        return !string.IsNullOrWhiteSpace(name) && !string.IsNullOrWhiteSpace(email) && email.Contains("@");
    }

    private async Task CreateStudent()
    {
        // Reset errors
        showNameError = false;
        showEmailError = false;
        errorMessage = string.Empty;
        successMessage = string.Empty;

        // Validate
        if (string.IsNullOrWhiteSpace(name))
        {
            showNameError = true;
            return;
        }

        if (string.IsNullOrWhiteSpace(email) || !email.Contains("@"))
        {
            showEmailError = true;
            return;
        }

        isSubmitting = true;

        try
        {
            var request = new { Name = name.Trim(), Email = email.Trim() };
            var response = await Http.PostAsJsonAsync("/api/admin/students", request);
            
            if (response.IsSuccessStatusCode)
            {
                successMessage = "Student created successfully! Redirecting...";
                await Task.Delay(1500); // Show success message
                Navigation.NavigateTo("/admin");
            }
            else
            {
                var errorContent = await response.Content.ReadAsStringAsync();
                errorMessage = $"Failed to create student: {response.StatusCode}";
                Console.WriteLine($"Error: {errorContent}");
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Error: {ex.Message}";
            Console.WriteLine($"Exception: {ex}");
        }
        finally
        {
            isSubmitting = false;
        }
    }

    private void GoBack()
    {
        Navigation.NavigateTo("/admin");
    }
}
