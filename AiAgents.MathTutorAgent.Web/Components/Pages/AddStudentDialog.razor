@page "/admin/add-student"
@attribute [Authorize(Roles = UserRoles.Admin)]
@using AiAgents.MathTutorAgent.Application.DTOs
@inject HttpClient Http
@inject NavigationManager Navigation
@inject UiPreferencesService UiPrefs
@inject NotificationService Notifications
@rendermode InteractiveServer
@implements IDisposable

<PageTitle>@($"{L("Dodaj učenika", "Add Student")} - MathTutor AI")</PageTitle>

<div class="qform-shell">
    <div class="qform-card">
        <div class="qform-header">
            <div>
                <h2>➕ @L("Dodaj novog učenika", "Add New Student")</h2>
                <p>@L("Kreiraj profil učenika i poveži ga sa prijavom.", "Create a student profile and connect it to login account flow.")</p>
            </div>
            <button class="qbtn ghost" @onclick="GoBack">
                ← @L("Nazad", "Back")
            </button>
        </div>

        @if (!string.IsNullOrWhiteSpace(inviteLink))
        {
            <div class="q-invite-note">
                <div>@L("Email servis je isključen ili slanje nije uspjelo. Pošalji ovaj invite link učeniku ručno:", "Email service is disabled or sending failed. Share this invite link with the student manually:")</div>
                <a href="@inviteLink" target="_blank" rel="noopener noreferrer">@inviteLink</a>
            </div>
        }

        <div class="qform-grid">
            <label class="full" for="name">
                @L("Ime učenika", "Student name")
                <input
                    id="name"
                    type="text"
                    class="qinput"
                    @bind="name"
                    placeholder="@L("Unesi puno ime", "Enter full name")"
                    disabled="@isSubmitting" />
                @if (showNameError)
                {
                    <span class="q-inline-error">@L("Ime je obavezno.", "Name is required.")</span>
                }
            </label>

            <label class="full" for="email">
                @L("Email adresa", "Email address")
                <input
                    id="email"
                    type="email"
                    class="qinput"
                    @bind="email"
                    placeholder="student@example.com"
                    disabled="@isSubmitting" />
                @if (showEmailError)
                {
                    <span class="q-inline-error">@L("Ispravan email je obavezan.", "Valid email is required.")</span>
                }
            </label>
        </div>

        <div class="qform-actions">
            <button
                    class="qbtn ghost"
                    @onclick="GoBack"
                    disabled="@isSubmitting">
                    @L("Otkaži", "Cancel")
                </button>
                <button
                    class="qbtn primary"
                    @onclick="CreateStudent"
                    disabled="@(isSubmitting || !IsValid())">
                    @(isSubmitting ? L("Kreiram...", "Creating...") : L("Kreiraj učenika", "Create Student"))
                </button>
        </div>
    </div>
</div>

@code {
    private string name = string.Empty;
    private string email = string.Empty;
    private bool isSubmitting = false;
    private bool showNameError = false;
    private bool showEmailError = false;
    private string? inviteLink;
    private string L(string bs, string en) => UiPrefs.Language == UiLanguage.Bs ? bs : en;

    protected override void OnInitialized()
    {
        UiPrefs.Changed += HandleLanguageChanged;
    }

    private void HandleLanguageChanged()
    {
        _ = InvokeAsync(StateHasChanged);
    }

    private bool IsValid()
    {
        return !string.IsNullOrWhiteSpace(name) && !string.IsNullOrWhiteSpace(email) && email.Contains("@");
    }

    private async Task CreateStudent()
    {
        // Reset errors
        showNameError = false;
        showEmailError = false;
        inviteLink = null;

        // Validate
        if (string.IsNullOrWhiteSpace(name))
        {
            showNameError = true;
            NotifyWarning(L("Ime učenika je obavezno.", "Student name is required."));
            return;
        }

        if (string.IsNullOrWhiteSpace(email) || !email.Contains("@"))
        {
            showEmailError = true;
            NotifyWarning(L("Unesi ispravnu email adresu učenika.", "Please enter a valid student email."));
            return;
        }

        isSubmitting = true;

        try
        {
            var request = new CreateStudentDto { Name = name.Trim(), Email = email.Trim() };
            var response = await Http.PostAsJsonAsync("/api/admin/students", request);
            
            if (response.IsSuccessStatusCode)
            {
                var payload = await response.Content.ReadFromJsonAsync<CreateStudentResultDto>();
                inviteLink = payload?.InviteLink;
                var successMessage = payload?.InviteSent == true
                    ? L("Uspješno ste kreirali učenika i poslali invite email.", "You successfully created the student and sent the invite email.")
                    : L("Uspješno ste kreirali učenika. Invite email nije poslan.", "You successfully created the student. Invite email was not sent.");
                NotifySuccess(successMessage);

                if (payload?.InviteSent == true)
                {
                    await Task.Delay(1200);
                    Navigation.NavigateTo("/admin?status=student-created");
                }
            }
            else
            {
                var errorContent = await response.Content.ReadAsStringAsync();
                var errorMessage = string.IsNullOrWhiteSpace(errorContent)
                    ? $"{L("Kreiranje učenika nije uspjelo", "Failed to create student")} ({response.StatusCode})."
                    : ExtractApiErrorMessage(errorContent);
                NotifyError(errorMessage);
            }
        }
        catch (Exception ex)
        {
            NotifyError($"{L("Greška", "Error")}: {ex.Message}");
        }
        finally
        {
            isSubmitting = false;
        }
    }

    private void GoBack()
    {
        Navigation.NavigateTo("/admin");
    }

    private static string ExtractApiErrorMessage(string raw)
    {
        try
        {
            using var doc = System.Text.Json.JsonDocument.Parse(raw);
            if (doc.RootElement.TryGetProperty("message", out var msgElement) &&
                msgElement.ValueKind == System.Text.Json.JsonValueKind.String)
            {
                return msgElement.GetString() ?? raw;
            }
        }
        catch
        {
            // ignore parse errors
        }

        return raw;
    }

    public void Dispose()
    {
        UiPrefs.Changed -= HandleLanguageChanged;
    }

    private void NotifySuccess(string detail)
        => Notifications.Notify(NotificationSeverity.Success, L("Uspješno", "Success"), detail, 4500);

    private void NotifyWarning(string detail)
        => Notifications.Notify(NotificationSeverity.Warning, L("Provjeri unos", "Check input"), detail, 4500);

    private void NotifyError(string detail)
        => Notifications.Notify(NotificationSeverity.Error, L("Neuspješno", "Failed"), detail, 6000);
}
