@using System.Text.RegularExpressions
@using AiAgents.MathTutorAgent.Web.Services
@inject UiPreferencesService UiPrefs

@if (!string.IsNullOrWhiteSpace(normalizedArea))
{
    <div class="area-visual-guide">
        <div class="avg-head">
            <h4>🧠 @L("Vizuelni vodič", "Visual Guide")</h4>
            <span class="avg-tag">@AreaName · @TopicName</span>
        </div>

        @switch (normalizedArea)
        {
            case "arithmetic":
                <div class="avg-card">
                    @if (TryParseBinaryExpression(QuestionText, out var a, out var op, out var b, out var result)
                        && IsVisualFriendlyArithmetic(a, op, b, result))
                    {
                        <div class="avg-equation">
                            <span class="avg-chip">@a</span>
                            <span class="avg-op">@OperatorToText(op)</span>
                            <span class="avg-chip">@b</span>
                            <span class="avg-op">=</span>
                            <span class="avg-chip answer">?</span>
                        </div>
                        @if (op == '+')
                        {
                            <p>@L("Prebroj jabuke iz obje grupe, pa upiši ukupan broj.", "Count apples from both groups, then write the total.")</p>
                            <div class="avg-group-wrap">
                                <div class="avg-group">
                                    <strong>@L("Grupa A", "Group A") (@a)</strong>
                                    <div class="avg-items">
                                        @for (var i = 0; i < a; i++)
                                        {
                                            <span class="avg-item">🍎</span>
                                        }
                                    </div>
                                </div>
                                <div class="avg-group">
                                    <strong>@L("Grupa B", "Group B") (@b)</strong>
                                    <div class="avg-items">
                                        @for (var i = 0; i < b; i++)
                                        {
                                            <span class="avg-item">🍎</span>
                                        }
                                    </div>
                                </div>
                            </div>
                        }
                        else if (op == '-')
                        {
                            <p>@L($"Precrtaj {b} jabuka, pa prebroj koliko je ostalo.", $"Cross out {b} apples, then count what remains.")</p>
                            <div class="avg-items">
                                @for (var i = 0; i < a; i++)
                                {
                                    var removed = i < b;
                                    <span class="avg-item @(removed ? "removed" : string.Empty)">🍎</span>
                                }
                            </div>
                        }
                        else if (op == '*')
                        {
                            <p>@L("Prebroj jednake grupe, pa odredi ukupan broj jabuka.", "Count equal groups, then find total apples.")</p>
                            <div class="avg-group-wrap">
                                @for (var row = 0; row < b; row++)
                                {
                                    <div class="avg-group">
                                        <strong>@L("Grupa", "Group") @(row + 1)</strong>
                                        <div class="avg-items">
                                            @for (var i = 0; i < a; i++)
                                            {
                                                <span class="avg-item">🍎</span>
                                            }
                                        </div>
                                    </div>
                                }
                            </div>
                        }
                        else if (op == '/')
                        {
                            <p>@L($"Podijeli {a} jabuka u {b} jednake grupe. Prebroj jabuke po grupi.", $"Share {a} apples into {b} equal groups. Count apples per group.")</p>
                            <div class="avg-group-wrap">
                                @for (var g = 0; g < b; g++)
                                {
                                    <div class="avg-group">
                                        <strong>@L("Grupa", "Group") @(g + 1)</strong>
                                        <div class="avg-items">
                                            @for (var i = 0; i < result; i++)
                                            {
                                                <span class="avg-item">🍎</span>
                                            }
                                        </div>
                                    </div>
                                }
                            </div>
                        }
                    }
                    else
                    {
                        <p>@L("Za veće brojeve koristi objašnjenje korak-po-korak umjesto brojanja objekata.", "For larger numbers, use step-by-step explanation instead of object counting.")</p>
                    }
                </div>
                break;

            case "prealgebra":
                <div class="avg-card">
                    <p>@L("Posmatraj nepoznatu kao kutiju i drži obje strane jednačine u ravnoteži.", "Think of the unknown as a box and keep both sides balanced.")</p>
                    <div class="avg-balance">
                        <div class="avg-pan">📦 + 3</div>
                        <div class="avg-center">⚖️</div>
                        <div class="avg-pan">8</div>
                    </div>
                </div>
                break;

            case "algebra":
                <div class="avg-card">
                    <p>@L("Izoluj promjenljivu tako što radiš istu operaciju na obje strane.", "Isolate the variable by doing the same operation on both sides.")</p>
                    <div class="avg-steps">
                        <span class="avg-step">x + 4 = 11</span>
                        <span class="avg-arrow">→</span>
                        <span class="avg-step">x = 11 - 4</span>
                        <span class="avg-arrow">→</span>
                        <span class="avg-step answer">x = 7</span>
                    </div>
                </div>
                break;

            case "logic":
                <div class="avg-card">
                    <p>@L("Provjeri tvrdnju kroz tačno/netačno slučajeve.", "Test the statement with true/false cases.")</p>
                    <div class="avg-logic-grid">
                        <div class="logic-cell true">A = @L("tačno", "true")</div>
                        <div class="logic-cell false">B = @L("netačno", "false")</div>
                        <div class="logic-cell result">A AND B = @L("netačno", "false")</div>
                    </div>
                </div>
                break;

            case "settheory":
                <div class="avg-card">
                    <p>@L("Koristi dva skupa i vizuelno istakni presjek/uniju.", "Use two sets and highlight intersection/union visually.")</p>
                    <div class="avg-venn">
                        <div class="venn a">A</div>
                        <div class="venn b">B</div>
                        <div class="venn mid">A ∩ B</div>
                    </div>
                </div>
                break;

            case "geometry":
                <div class="avg-card">
                    <p>@L("Prvo prepoznaj osobine oblika, zatim primijeni formulu.", "Recognize shape properties first, then apply formula.")</p>
                    <div class="avg-geo">
                        <div class="shape square"></div>
                        <div class="shape triangle"></div>
                        <div class="shape circle"></div>
                    </div>
                </div>
                break;

            case "proofs":
                <div class="avg-card">
                    <p>@L("Gradi dokaz kao lanac opravdanih koraka.", "Build proof as a chain of justified steps.")</p>
                    <div class="avg-proof">
                        <span class="proof-node">@L("Dato", "Given")</span>
                        <span class="avg-arrow">→</span>
                        <span class="proof-node">@L("Pravilo", "Rule")</span>
                        <span class="avg-arrow">→</span>
                        <span class="proof-node answer">@L("Zaključak", "Conclusion")</span>
                    </div>
                </div>
                break;

            default:
                break;
        }
    </div>
}

@code {
    [Parameter] public string? AreaName { get; set; }
    [Parameter] public string? TopicName { get; set; }
    [Parameter] public string? QuestionText { get; set; }

    private string normalizedArea = string.Empty;
    private string L(string bs, string en) => UiPrefs.Language == UiLanguage.Bs ? bs : en;

    protected override void OnParametersSet()
    {
        normalizedArea = NormalizeArea(AreaName);
    }

    private static string NormalizeArea(string? area)
    {
        if (string.IsNullOrWhiteSpace(area))
        {
            return string.Empty;
        }

        var normalized = area.Replace(" ", string.Empty).ToLowerInvariant();

        return normalized switch
        {
            "arithmetic" or "aritmetika" => "arithmetic",
            "prealgebra" or "predalgebra" => "prealgebra",
            "algebra" => "algebra",
            "logic" or "logika" => "logic",
            "settheory" or "teorijaskupova" => "settheory",
            "geometry" or "geometrija" => "geometry",
            "proofs" or "dokazi" => "proofs",
            _ => string.Empty
        };
    }

    private static string OperatorToText(char op)
    {
        return op switch
        {
            '*' => "×",
            '/' => "÷",
            _ => op.ToString()
        };
    }

    private static bool TryParseBinaryExpression(string? text, out int a, out char op, out int b, out int result)
    {
        a = 0;
        b = 0;
        result = 0;
        op = '+';

        if (string.IsNullOrWhiteSpace(text))
        {
            return false;
        }

        var match = Regex.Match(text, @"(?<!\d)(\d+)\s*([+\-−xX*÷/×])\s*(\d+)");
        if (!match.Success)
        {
            return false;
        }

        a = int.Parse(match.Groups[1].Value);
        var raw = match.Groups[2].Value;
        b = int.Parse(match.Groups[3].Value);

        op = raw switch
        {
            "x" or "X" or "×" => '*',
            "÷" => '/',
            "−" => '-',
            _ => raw[0]
        };

        if (op == '-' && a < b)
        {
            return false;
        }

        if (op == '/' && (b == 0 || a % b != 0))
        {
            return false;
        }

        result = op switch
        {
            '+' => a + b,
            '-' => a - b,
            '*' => a * b,
            '/' => a / b,
            _ => -1
        };

        return result >= 0;
    }

    private static bool IsVisualFriendlyArithmetic(int a, char op, int b, int result)
    {
        // Only show concrete-object visuals for beginner-size tasks.
        // This prevents unrealistic outputs like 262 apples.
        return op switch
        {
            '+' => a <= 10 && b <= 10 && result <= 20,
            '-' => a <= 20 && b <= 10 && a >= b && result <= 12,
            '*' => a <= 5 && b <= 5 && result <= 25,
            '/' => b > 0 && a % b == 0 && a <= 20 && b <= 5 && result <= 10,
            _ => false
        };
    }
}
