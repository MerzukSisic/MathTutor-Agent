@page "/forgot_password"
@attribute [AllowAnonymous]
@using System.Text.Json
@inject IJSRuntime JS
@inject UiPreferencesService UiPrefs
@implements IDisposable

<PageTitle>@($"{L("Zaboravljena lozinka", "Forgot Password")} - MathTutor AI")</PageTitle>

<div class="auth-page">
    <div class="auth-card">
        <h1>@L("Zaboravljena lozinka", "Forgot Password")</h1>
        <p>@L("Unesi email i poslat ćemo ti link za reset.", "Enter your email and we'll send you a reset link.")</p>

        @if (!string.IsNullOrWhiteSpace(message))
        {
            <div class="auth-alert info">@message</div>
        }

        @if (!string.IsNullOrWhiteSpace(errorMessage))
        {
            <div class="auth-alert error">@errorMessage</div>
        }

        <label>
            @L("Email", "Email")
            <input class="auth-input" type="email" @bind="email" autocomplete="username" />
        </label>

        <button class="auth-btn" @onclick="RequestResetAsync" disabled="@isSubmitting">
            @(isSubmitting ? L("Šaljem...", "Sending...") : L("Pošalji link za reset", "Send Reset Link"))
        </button>

        <p class="auth-meta"><a href="/login">@L("Nazad na prijavu", "Back to login")</a></p>
    </div>
</div>

@code {
    private string email = string.Empty;
    private string? message;
    private string? errorMessage;
    private bool isSubmitting;
    private string L(string bs, string en) => UiPrefs.Language == UiLanguage.Bs ? bs : en;

    protected override void OnInitialized()
    {
        UiPrefs.Changed += HandleLanguageChanged;
    }

    private void HandleLanguageChanged()
    {
        _ = InvokeAsync(StateHasChanged);
    }

    private async Task RequestResetAsync()
    {
        message = null;
        errorMessage = null;

        if (string.IsNullOrWhiteSpace(email))
        {
            errorMessage = L("Email je obavezan.", "Email is required.");
            return;
        }

        isSubmitting = true;

        try
        {
            var result = await JS.InvokeAsync<JsonElement>("authFetch", "/api/auth/forgot_password", new { email });
            string? msg = null;
            if (result.TryGetProperty("data", out var data) && data.ValueKind != JsonValueKind.Null)
            {
                data.TryGetProperty("message", out var msgEl);
                msg = msgEl.ValueKind == JsonValueKind.String ? msgEl.GetString() : null;
            }

            message = string.IsNullOrWhiteSpace(msg)
                ? L("Ako nalog postoji, link za reset je poslan.", "If the account exists, a reset link has been sent.")
                : msg;
        }
        catch
        {
            errorMessage = L("Trenutno nije moguće poslati link za reset.", "Unable to send reset link right now.");
        }
        finally
        {
            isSubmitting = false;
        }
    }

    public void Dispose()
    {
        UiPrefs.Changed -= HandleLanguageChanged;
    }
}
