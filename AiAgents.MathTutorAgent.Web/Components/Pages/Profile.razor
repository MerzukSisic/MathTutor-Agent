}

.topic-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 0.75rem;
}

.topic-name {
    font-weight: 600;
    color: #111827;
    font-size: 0.95rem;
}

.topic-score {
    font-weight: 700;
    color: #3b82f6;
    font-size: 1.1rem;
}

.topic-progress-bar {
    height: 8px;
    background: #e5e7eb;
    border-radius: 50px;
    overflow: hidden;
