@page "/profile/{studentId:int}"
@attribute [Authorize]
@inject HttpClient Http
@inject IJSRuntime JS
@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthStateProvider
@inject UiPreferencesService UiPrefs
@inject AiAgents.MathTutorAgent.Application.Services.MathContentLocalizationService ContentLocalization
@implements IDisposable

<PageTitle>@($"{L("Profil učenika", "Student Profile")} - MathTutor AI")</PageTitle>

<div class="profile-container theme-@UiPrefs.ThemeCode">
    @if (profile == null)
    {
            <div class="loading-container">
                <div class="spinner-large"></div>
            <p class="loading-text">@L("Učitavanje profila...", "Loading profile...")</p>
        </div>
    }
    else
    {
        <!-- Header Section -->
        <div class="profile-header">
            <div class="profile-header-content">
                <div class="profile-avatar-section">
                    <div class="profile-avatar-large">
                        @GetInitials(profile.Name)
                    </div>
                    <div class="profile-info">
                        <h1 class="profile-name">@profile.Name</h1>
                        <p class="profile-email">@profile.Email</p>
                        <div class="profile-badges">
                            <span class="badge badge-primary">
                                <span class="badge-icon">🎯</span>
                                @profile.AccuracyPercentage.ToString("F1")% @L("Tačnost", "Accuracy")
                            </span>
                            <span class="badge badge-secondary">
                                <span class="badge-icon">🧠</span>
                                @profile.ReadinessLabel
                            </span>
                            @if (profile.TotalAttempts >= 100)
                            {
                                <span class="badge badge-gold">
                                    <span class="badge-icon">🏆</span>
                                    @L("Klub 100+", "Century Club")
                                </span>
                            }
                        </div>
                    </div>
                </div>
                <div class="profile-actions">
                    <button class="btn-icon-primary" @onclick="ExportPdf" title="@L("Izvezi PDF", "Export PDF")">
                        <span class="icon">📄</span>
                        <span class="text">@L("Izvezi PDF", "Export PDF")</span>
                    </button>
                    @if (isAdmin)
                    {
                        <button class="btn-icon-secondary" @onclick="BackToDashboard" title="@L("Nazad", "Back")">
                            <span class="icon">←</span>
                            <span class="text">@L("Kontrolna tabla", "Dashboard")</span>
                        </button>
                    }
                </div>
            </div>
        </div>

        <!-- Stats Overview -->
        <div class="stats-overview">
            <div class="stat-card-modern">
                <div class="stat-icon-wrapper stat-blue">
                    <span class="stat-icon">📝</span>
                </div>
                <div class="stat-details">
                    <p class="stat-label">@L("Ukupno pokušaja", "Total Attempts")</p>
                    <p class="stat-value">@profile.TotalAttempts</p>
                    <p class="stat-trend">
                        <span class="trend-indicator">↑</span>
                        @L("Samo nastavi!", "Keep going!")
                    </p>
                </div>
            </div>

            <div class="stat-card-modern">
                <div class="stat-icon-wrapper stat-green">
                    <span class="stat-icon">✅</span>
                </div>
                <div class="stat-details">
                    <p class="stat-label">@L("Tačni odgovori", "Correct Answers")</p>
                    <p class="stat-value">@profile.CorrectAttempts</p>
                    <p class="stat-trend">
                        <span class="trend-indicator">✓</span>
                        @((profile.CorrectAttempts * 100.0 / Math.Max(profile.TotalAttempts, 1)).ToString("F1"))%
                    </p>
                </div>
            </div>

            <div class="stat-card-modern">
                <div class="stat-icon-wrapper stat-teal">
                    <span class="stat-icon">⚡</span>
                </div>
                <div class="stat-details">
                    <p class="stat-label">@L("Prosj. vrijeme odgovora", "Avg Response Time")</p>
                    <p class="stat-value">@profile.AverageTimeSeconds.ToString("F1")s</p>
                    <p class="stat-trend">
                        <span class="trend-indicator">⏱️</span>
                        @L("Po pitanju", "Per question")
                    </p>
                </div>
            </div>

            <div class="stat-card-modern">
                <div class="stat-icon-wrapper stat-orange">
                    <span class="stat-icon">🎯</span>
                </div>
                <div class="stat-details">
                    <p class="stat-label">@L("Ukupna tačnost", "Overall Accuracy")</p>
                    <p class="stat-value">@profile.AccuracyPercentage.ToString("F1")%</p>
                    <p class="stat-trend">
                        <span class="trend-indicator">📈</span>
                        @GetAccuracyStatus(profile.AccuracyPercentage)
                    </p>
                </div>
            </div>

            <div class="stat-card-modern">
                <div class="stat-icon-wrapper stat-blue">
                    <span class="stat-icon">🥇</span>
                </div>
                <div class="stat-details">
                    <p class="stat-label">@L("Uspjeh iz prve", "First Try Success")</p>
                    <p class="stat-value">@profile.FirstTrySuccessRate.ToString("F1")%</p>
                    <p class="stat-trend">
                        <span class="trend-indicator">📌</span>
                        @L("Po pitanju", "Per question")
                    </p>
                </div>
            </div>

            <div class="stat-card-modern">
                <div class="stat-icon-wrapper stat-green">
                    <span class="stat-icon">🎚️</span>
                </div>
                <div class="stat-details">
                    <p class="stat-label">@L("Preporučena težina", "Suggested Difficulty")</p>
                    <p class="stat-value">@profile.SuggestedDifficulty / 5</p>
                    <p class="stat-trend">
                        <span class="trend-indicator">⚙️</span>
                        @L("Adaptivna preporuka", "Adaptive recommendation")
                    </p>
                </div>
            </div>
        </div>

        <!-- Main Content Grid -->
        <div class="content-grid">
            <!-- Topic Mastery -->
            <div class="content-card">
                <div class="card-header">
                    <h3 class="card-title">
                        <span class="title-icon">📊</span>
                        @L("Vladanje temama", "Topic Mastery")
                    </h3>
                </div>
                <div class="card-body">
                    @if (profile.TopicProgress.Any())
                    {
                        <div class="topic-progress-list">
                            @foreach (var topic in profile.TopicProgress.OrderByDescending(t => t.MasteryScore).Take(10))
                            {
                                <button type="button"
                                        class="topic-item @(IsTopicActive(topic) ? "active" : string.Empty)"
                                        @onclick="() => ApplyTopicFilter(topic)">
                                    <div class="topic-header">
                                        <span class="topic-name">@topic.TopicName <span class="topic-area">@topic.AreaName</span></span>
                                        <span class="topic-score">@topic.MasteryScore.ToString("F0")%</span>
                                    </div>
                                    <div class="topic-progress-bar">
                                        <div class="progress-fill" style="width: @topic.MasteryScore%">
                                            <div class="progress-glow"></div>
                                        </div>
                                    </div>
                                    <div class="topic-meta">
                                        <span class="confidence-indicator">
                                            @GetConfidenceIcon(topic.Confidence) 
                                            @((topic.Confidence * 100).ToString("F0"))% @L("pouzdanost", "confidence")
                                        </span>
                                        <span class="last-practiced">
                                            @L("Zadnje", "Last"): @GetRelativeTime(topic.LastPracticed)
                                        </span>
                                    </div>
                                </button>
                            }
                        </div>
                        
                        <!-- Chart -->
                        <div class="chart-container">
                            <canvas id="topicChart"></canvas>
                        </div>
                    }
                    else
                    {
                        <div class="empty-state-small">
                            <span class="empty-icon">📚</span>
                            <p>@L("Još nema savladanih tema", "No topics mastered yet")</p>
                            <p class="empty-subtitle">@L("Počni rješavati pitanja da vidiš napredak", "Start solving questions to see your progress")</p>
                        </div>
                    }
                </div>
            </div>

            <!-- Recent Activity Feed -->
            <div class="content-card">
                <div class="card-header">
                    <h3 class="card-title">
                        <span class="title-icon">⚡</span>
                        @L("Nedavne aktivnosti", "Recent Activity")
                    </h3>
                    @if (HasAnyFilter)
                    {
                        <div class="filter-pill">
                            @ActiveFilterLabel
                            <button type="button" class="clear-filter-btn" @onclick="ClearFilters">@L("Očisti", "Clear")</button>
                        </div>
                    }
                </div>
                <div class="card-body">
                    @if (FilteredRecentActivity.Any())
                    {
                        <div class="activity-feed">
                            @foreach (var activity in FilteredRecentActivity.Take(10))
                            {
                                <div class="activity-card @(activity.IsCorrect ? "activity-success" : "activity-error")">
                                    <div class="activity-indicator">
                                        @if (activity.IsCorrect)
                                        {
                                            <span class="activity-icon success">✓</span>
                                        }
                                        else
                                        {
                                            <span class="activity-icon error">✗</span>
                                        }
                                    </div>
                                    <div class="activity-content">
                                        <p class="activity-question">@LocalizeQuestionForUi(activity.QuestionText)</p>
                                        <div class="activity-meta">
                                            <span class="activity-time">
                                                🕒 @activity.TimeSeconds.ToString("F1")s
                                            </span>
                                            <span class="activity-topic">@activity.TopicName</span>
                                            <span class="activity-area">@activity.AreaName</span>
                                            <span class="activity-date">
                                                @GetRelativeTime(activity.Date)
                                            </span>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="empty-state-small">
                            <span class="empty-icon">📝</span>
                            <p>@(HasAnyFilter ? L("Nema aktivnosti za izabrani filter", "No activity for selected filter") : L("Još nema aktivnosti", "No activity yet"))</p>
                            <p class="empty-subtitle">@(HasAnyFilter ? L("Probaj drugu temu/oblast ili očisti filter", "Try another topic/area or clear filter") : L("Počni rješavati pitanja da izgradiš historiju", "Start solving questions to build your history"))</p>
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- Daily Performance Chart -->
        @if (stats != null && stats.DailyStats.Any())
        {
            <div class="content-card chart-card">
                <div class="card-header">
                    <h3 class="card-title">
                        <span class="title-icon">📈</span>
                        @L("Dnevni učinak (zadnjih 30 dana)", "Daily Performance (Last 30 Days)")
                    </h3>
                </div>
                <div class="card-body">
                    <div class="chart-container-large">
                        <canvas id="dailyChart"></canvas>
                    </div>
                </div>
            </div>
        }

        @if (profile.AreaAttemptInsights.Any())
        {
            <div class="content-card chart-card">
                <div class="card-header">
                    <h3 class="card-title">
                        <span class="title-icon">🧩</span>
                        @L("Pokušaji po oblasti", "Attempts by Area")
                    </h3>
                </div>
                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table table-elevated">
                            <thead class="table-head">
                                <tr>
                                    <th>@L("Oblast", "Area")</th>
                                    <th>@L("Ukupno pokušaja", "Total Attempts")</th>
                                    <th>@L("Jedinstvena pitanja", "Unique Questions")</th>
                                    <th>@L("Tačnost", "Accuracy")</th>
                                    <th>@L("Iz prve", "First Try")</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var area in profile.AreaAttemptInsights)
                                {
                                    <tr class="@(IsAreaActive(area.AreaName) ? "area-row active" : "area-row")"
                                        @onclick="() => ApplyAreaFilter(area.AreaName)">
                                        <td><span class="table-area-badge">@area.AreaName</span></td>
                                        <td>@area.TotalAttempts</td>
                                        <td>@area.UniqueQuestions</td>
                                        <td>@area.AccuracyPercentage.ToString("F1")%</td>
                                        <td>@area.FirstTrySuccessRate.ToString("F1")%</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        }

        @if (profile.QuestionAttemptInsights.Any())
        {
            <div class="content-card chart-card">
                <div class="card-header">
                    <h3 class="card-title">
                        <span class="title-icon">🔁</span>
                        @L("Najčešće ponavljana pitanja", "Most Retried Questions")
                    </h3>
                </div>
                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table table-elevated">
                            <thead class="table-head">
                                <tr>
                                    <th>@L("Pitanje", "Question")</th>
                                    <th>@L("Oblast", "Area")</th>
                                    <th>@L("Pokušaji", "Attempts")</th>
                                    <th>@L("Tačnost", "Accuracy")</th>
                                    <th>@L("Riješeno iz prve", "Solved First Try")</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (!FilteredQuestionInsights.Any())
                                {
                                    <tr class="table-empty-row">
                                        <td colspan="5">@L("Nema pitanja za izabranu oblast.", "No questions for selected area.")</td>
                                    </tr>
                                }

                                @foreach (var q in FilteredQuestionInsights.OrderByDescending(x => x.AttemptsCount).Take(8))
                                {
                                    <tr class="question-row">
                                        <td>@LocalizeQuestionForUi(q.QuestionText)</td>
                                        <td><span class="table-area-badge">@q.AreaName</span></td>
                                        <td>@q.AttemptsCount</td>
                                        <td>@q.AccuracyPercentage.ToString("F1")%</td>
                                        <td>@(q.SolvedFromFirstTry ? L("Da", "Yes") : L("Ne", "No"))</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        }
    }
</div>

@code {
    [Parameter]
    public int StudentId { get; set; }

    private StudentProfileDto? profile;
    private StudySessionStatsDto? stats;
    private bool isAdmin;
    private string? selectedAreaFilter;
    private string? selectedTopicNameFilter;
    private string? selectedTopicAreaFilter;
    private string L(string bs, string en) => UiPrefs.Language == UiLanguage.Bs ? bs : en;
    private string LocalizeQuestionForUi(string? questionText) =>
        ContentLocalization.LocalizeQuestionText(questionText, UiPrefs.LanguageCode);

    private bool HasAreaFilter => !string.IsNullOrWhiteSpace(selectedAreaFilter);
    private bool HasTopicFilter => !string.IsNullOrWhiteSpace(selectedTopicNameFilter)
        && !string.IsNullOrWhiteSpace(selectedTopicAreaFilter);
    private bool HasAnyFilter => HasAreaFilter || HasTopicFilter;
    private string ActiveFilterLabel => HasTopicFilter
        ? $"{L("Tema", "Topic")}: {selectedTopicNameFilter} ({selectedTopicAreaFilter})"
        : $"{L("Oblast", "Area")}: {selectedAreaFilter}";

    private IEnumerable<ActivityDto> FilteredRecentActivity => profile?.RecentActivity
        .Where(a =>
            !HasAnyFilter ||
            (HasTopicFilter && IsTopicMatch(a.TopicName, a.AreaName)) ||
            (!HasTopicFilter && HasAreaFilter && string.Equals(a.AreaName, selectedAreaFilter, StringComparison.OrdinalIgnoreCase)))
        ?? Enumerable.Empty<ActivityDto>();

    private IEnumerable<QuestionAttemptInsightDto> FilteredQuestionInsights => profile?.QuestionAttemptInsights
        .Where(q =>
            !HasAnyFilter ||
            (HasTopicFilter && IsTopicMatch(q.TopicName, q.AreaName)) ||
            (!HasTopicFilter && HasAreaFilter && string.Equals(q.AreaName, selectedAreaFilter, StringComparison.OrdinalIgnoreCase)))
        ?? Enumerable.Empty<QuestionAttemptInsightDto>();

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        isAdmin = authState.User.IsInRole(UserRoles.Admin);
        UiPrefs.Changed += HandleLanguageChanged;

        await LoadProfile();
        await LoadStats();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && profile != null)
        {
            await RenderCharts();
        }
    }

    private async Task LoadProfile()
    {
        try
        {
            profile = await Http.GetFromJsonAsync<StudentProfileDto>($"/api/student/{StudentId}/profile?lang={UiPrefs.LanguageCode}");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading profile: {ex.Message}");
        }
    }

    private async Task LoadStats()
    {
        try
        {
            var fromDate = DateTime.UtcNow.AddDays(-30);
            var toDate = DateTime.UtcNow;
            stats = await Http.GetFromJsonAsync<StudySessionStatsDto>(
                $"/api/student/{StudentId}/stats?from={fromDate:yyyy-MM-dd}&to={toDate:yyyy-MM-dd}&lang={UiPrefs.LanguageCode}");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading stats: {ex.Message}");
        }
    }

    private async Task RenderCharts()
    {
        if (profile == null) return;

        try
        {
            await Task.Delay(100); // Give DOM time to render

            if (profile.TopicProgress.Any())
            {
                var topicLabels = profile.TopicProgress.Select(t => t.TopicName).ToArray();
                var topicScores = profile.TopicProgress.Select(t => t.MasteryScore).ToArray();
                await JS.InvokeVoidAsync("renderTopicChart", topicLabels, topicScores);
            }

            if (stats != null && stats.DailyStats.Any())
            {
                var dailyLabels = stats.DailyStats.Select(d => d.Date.ToString("MMM dd")).ToArray();
                var dailyAttempts = stats.DailyStats.Select(d => d.TotalAttempts).ToArray();
                var dailyCorrect = stats.DailyStats.Select(d => d.CorrectAttempts).ToArray();
                await JS.InvokeVoidAsync("renderDailyChart", dailyLabels, dailyAttempts, dailyCorrect);
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error rendering charts: {ex.Message}");
        }
    }

    private async Task ExportPdf()
    {
        try
        {
            var response = await Http.GetAsync($"/api/student/{StudentId}/export_pdf?lang={UiPrefs.LanguageCode}");
            if (response.IsSuccessStatusCode)
            {
                var fileBytes = await response.Content.ReadAsByteArrayAsync();
                var fileName = $"MathTutor_Report_{StudentId}_{DateTime.Now:yyyyMMdd}.pdf";
                await JS.InvokeVoidAsync("downloadFile", fileName, Convert.ToBase64String(fileBytes));
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error exporting PDF: {ex.Message}");
        }
    }

    private void BackToDashboard()
    {
        if (isAdmin)
        {
            Navigation.NavigateTo("/");
            return;
        }

        Navigation.NavigateTo($"/quiz/{StudentId}");
    }

    private string GetInitials(string name)
    {
        var parts = name.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        if (parts.Length >= 2)
            return $"{parts[0][0]}{parts[1][0]}".ToUpper();
        return parts.Length > 0 ? parts[0][..Math.Min(2, parts[0].Length)].ToUpper() : "??";
    }

    private string GetConfidenceIcon(double confidence)
    {
        return confidence switch
        {
            >= 0.8 => "🔥",
            >= 0.6 => "✨",
            >= 0.4 => "💫",
            _ => "🌱"
        };
    }

    private string GetAccuracyStatus(double accuracy)
    {
        return accuracy switch
        {
            >= 90 => L("Odlično!", "Excellent!"),
            >= 75 => L("Vrlo dobro", "Very Good"),
            >= 60 => L("Dobro", "Good"),
            >= 50 => L("Nastavi vježbati", "Keep Practicing"),
            _ => L("Potrebno je još vježbe", "More Practice Needed")
        };
    }

    private void HandleLanguageChanged()
    {
        _ = InvokeAsync(async () =>
        {
            await LoadProfile();
            await LoadStats();
            await RenderCharts();
            StateHasChanged();
        });
    }

    public void Dispose()
    {
        UiPrefs.Changed -= HandleLanguageChanged;
    }

    private string GetRelativeTime(DateTime date)
    {
        var span = DateTime.UtcNow - date;
        
        if (span.TotalMinutes < 1) return L("upravo sada", "just now");
        if (span.TotalMinutes < 60) return UiPrefs.Language == UiLanguage.Bs
            ? $"prije {(int)span.TotalMinutes} min"
            : $"{(int)span.TotalMinutes}m ago";
        if (span.TotalHours < 24) return UiPrefs.Language == UiLanguage.Bs
            ? $"prije {(int)span.TotalHours} h"
            : $"{(int)span.TotalHours}h ago";
        if (span.TotalDays < 7) return UiPrefs.Language == UiLanguage.Bs
            ? $"prije {(int)span.TotalDays} d"
            : $"{(int)span.TotalDays}d ago";
        if (span.TotalDays < 30) return UiPrefs.Language == UiLanguage.Bs
            ? $"prije {(int)(span.TotalDays / 7)} sedm"
            : $"{(int)(span.TotalDays / 7)}w ago";
        
        return date.ToString("MMM dd, yyyy");
    }

    private void ApplyTopicFilter(TopicProgressDto topic)
    {
        if (IsTopicActive(topic))
        {
            ClearFilters();
            return;
        }

        selectedTopicNameFilter = topic.TopicName;
        selectedTopicAreaFilter = topic.AreaName;
        selectedAreaFilter = null;
    }

    private void ApplyAreaFilter(string areaName)
    {
        if (IsAreaActive(areaName))
        {
            ClearFilters();
            return;
        }

        selectedAreaFilter = areaName;
        selectedTopicNameFilter = null;
        selectedTopicAreaFilter = null;
    }

    private bool IsAreaActive(string areaName)
    {
        return !HasTopicFilter && string.Equals(selectedAreaFilter, areaName, StringComparison.OrdinalIgnoreCase);
    }

    private bool IsTopicActive(TopicProgressDto topic)
    {
        return HasTopicFilter && IsTopicMatch(topic.TopicName, topic.AreaName);
    }

    private bool IsTopicMatch(string topicName, string areaName)
    {
        return string.Equals(topicName, selectedTopicNameFilter, StringComparison.OrdinalIgnoreCase)
            && string.Equals(areaName, selectedTopicAreaFilter, StringComparison.OrdinalIgnoreCase);
    }

    private void ClearFilters()
    {
        selectedAreaFilter = null;
        selectedTopicNameFilter = null;
        selectedTopicAreaFilter = null;
    }
}
