}

.activity-meta {
    display: flex;
    gap: 1rem;
    font-size: 0.8125rem;
    color: #6b7280;
}

/* Charts */
.chart-container {
    margin-top: 1.5rem;
    padding: 1rem;
    background: #f9fafb;
    border-radius: 12px;
}

.chart-card {
    grid-column: 1 / -1;
}

.chart-container-large {
    padding: 1.5rem;
    background: #f9fafb;
    border-radius: 12px;
}

/* Empty States */
.empty-state-small {
    text-align: center;
    padding: 3rem 1rem;
}

.empty-icon {
    font-size: 4rem;
    display: block;
    margin-bottom: 1rem;
    opacity: 0.6;
}

.empty-state-small p {
    margin: 0.5rem 0;
    color: #6b7280;
}

.empty-subtitle {
    font-size: 0.875rem;
    color: #9ca3af;
}

/* Responsive */
@@media (max-width: 768px) {
    .profile-container {
        padding: 1rem;
    }

    .profile-header {
        padding: 1.5rem;
    }

    .profile-header-content {
        flex-direction: column;
        align-items: flex-start;
    }

    .profile-avatar-large {
        width: 80px;
        height: 80px;
        font-size: 2rem;
    }

    .profile-name {
        font-size: 1.5rem;
    }

    .stats-overview {
        grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
    }

    .stat-value {
        font-size: 1.5rem;
    }

    .content-grid {
        grid-template-columns: 1fr;
    }
    }
